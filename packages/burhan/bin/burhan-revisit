#!/usr/bin/env python3
"""burhan-revisit — auto-highlight branches in a burhan plan that need attention.

Five actions surfaced (per khazīna plan/07-maintenance-disciplines.md and
mizaj rule 11/14 audit-discipline):

  EXPLORE — claim has low confidence (< --explore-floor) AND no `by audit`
            citation OR no receipt-anchored derivation. The plan needs
            more research / measurement on this branch.

  MOVE    — claim is fact-shape (literal payload, no theorem citation, no
            derivation from other claims) but lives in a non-facts file
            (e.g. PLAN.bn). Suggests it should be relocated to facts/*.bn
            so PLAN.bn stays at architectural-decision granularity.

  DISSECT — claim aggregates ≥3 derivations AND its confidence == min(deps).
            The aggregation produces no value-add over the weakest dep —
            the operator may want to split the claim into per-dep sub-claims
            so the weak link is named.

  MERGE   — two claims share ≥ --merge-overlap of their derivation set OR
            have very similar payload reprs. Candidates to consolidate.

  REMOVE  — claim is not in the transitive cite-closure of any discharge
            claim (per --discharge patterns). It's orphaned; consider
            removing OR explicitly marking as a fact file entry.

Optional MAIN.md drift signal: if --baseline-snapshot is supplied AND its
tracked_files hash for MAIN.md differs from the current MAIN.md, surface
"MAIN.md drift" — every goal-bound claim should be re-audited.

Output: markdown report grouped by action, sorted by claim-name within
each group. Exit non-zero if --strict and any item surfaces.
"""

from __future__ import annotations

import argparse
import functools
import hashlib
import json
import sys
from difflib import SequenceMatcher
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(ROOT / "src"))

from burhan.evaluator import Evaluator  # noqa: E402
from burhan.parser import parse_program  # noqa: E402


def _sha256(path: Path) -> str:
    return hashlib.sha256(path.read_bytes()).hexdigest()


def _collect_bn_files(paths: list[Path]) -> list[Path]:
    out: list[Path] = []
    for p in paths:
        if p.is_dir():
            out.extend(sorted(p.rglob("*.bn")))
        elif p.suffix == ".bn":
            out.append(p)
    return out


def _claim_lines(source: str) -> dict[str, int]:
    lines: dict[str, int] = {}
    for i, raw in enumerate(source.splitlines(), start=1):
        line = raw.strip()
        if line.startswith("claim "):
            try:
                _, rest = line.split(" ", 1)
                name = rest.split(":", 1)[0].split(" ", 1)[0].split("=", 1)[0].strip()
                if name and name not in lines:
                    lines[name] = i
            except ValueError:
                pass
    return lines


def _has_audit_citation(source: str, claim_name: str) -> bool:
    """Check if the lines defining or near `claim claim_name` include `by audit`."""
    lines = source.splitlines()
    for i, raw in enumerate(lines):
        if raw.strip().startswith(f"claim {claim_name}"):
            # check this line + next 5 lines
            window = "\n".join(lines[i : i + 6])
            if "by audit" in window or "by observation" in window:
                return True
    return False


def _falsifier_referenced_names(source: str) -> set[str]:
    """Names referenced inside `falsified_when ...` clauses across the source.

    These claims are typically observation-shaped (Bool literal payloads) that
    exist to bind a theorem's falsifier to an externally-observable predicate.
    They are NOT candidates for MOVE or REMOVE even when fact-shape.
    """
    import re as _re
    names: set[str] = set()
    src = source
    for m in _re.finditer(r"falsified_when\s+(.+?)(?=\n\s*(?:claim |theorem |lemma |assume |proves |#|$))",
                          src, _re.DOTALL):
        body = m.group(1)
        for ident in _re.finditer(r"\b([a-zA-Z_][a-zA-Z0-9_]*)\b", body):
            names.add(ident.group(1))
    return names


def _theorem_references(source: str) -> dict[str, set[str]]:
    """Map theorem-name → identifiers referenced in its `proves` predicate.

    The closure walker uses this to follow `claim X = cite theorem_T` →
    `theorem_T proves f(claim_Y, claim_Z)` → claim_Y, claim_Z.
    Without this, intermediate claims used inside theorem `proves` clauses
    look like orphans even when they're load-bearing for a discharge.

    Anchored to start-of-line so `# This theorem ties...` in comments
    doesn't false-match as a theorem definition.
    """
    import re as _re
    refs: dict[str, set[str]] = {}
    pattern = _re.compile(
        r"^theorem\s+(\w+)(.*?)^\s*proves\s+(.+?)(?=^\s*by\b|\Z)",
        _re.DOTALL | _re.MULTILINE,
    )
    for m in pattern.finditer(source):
        name = m.group(1)
        body = m.group(2) + " " + m.group(3)
        idents: set[str] = set()
        for ident in _re.finditer(r"\b([a-zA-Z_][a-zA-Z0-9_]*)\b", body):
            tok = ident.group(1)
            if tok in {"and", "or", "not", "True", "False", "None",
                       "assume", "proves", "by", "audit", "observation",
                       "Bool", "Int", "Float", "Str", "List"}:
                continue
            idents.add(tok)
        refs[name] = idents
    return refs


def _is_fact_shape(claim_info: dict, source: str, claim_name: str) -> bool:
    """Fact-shape: literal payload, no derivation, no falsifier, no cite."""
    if claim_info["derivation"]:
        return False
    if claim_info["falsifier"] is not None:
        return False
    payload_repr = claim_info.get("payload_repr", "")
    # literal: bool/int/float/str
    is_literal = (
        payload_repr.startswith("'") or payload_repr.startswith('"')
        or payload_repr in {"True", "False"}
        or payload_repr.replace("-", "", 1).replace(".", "", 1).isdigit()
    )
    return is_literal


def _is_in_facts_dir(file_path: str | None) -> bool:
    return file_path is not None and "/facts/" in file_path


def main(argv: list[str] | None = None) -> int:
    ap = argparse.ArgumentParser(prog="burhan-revisit")
    ap.add_argument("paths", nargs="+", help="Files or directories containing .bn files")
    ap.add_argument("--main", default=None, help="MAIN.md path to track for drift")
    ap.add_argument("--baseline-snapshot", default=None, help="Prior snapshot to detect MAIN.md drift")
    ap.add_argument("--explore-floor", type=float, default=0.85, help="Below this confidence → flag for explore")
    ap.add_argument("--dissect-min-deps", type=int, default=3, help="Aggregation threshold for dissect heuristic")
    ap.add_argument("--merge-overlap", type=float, default=0.8, help="Derivation-set overlap threshold for merge")
    ap.add_argument("--merge-text-similarity", type=float, default=0.85, help="Payload-repr similarity threshold for merge")
    ap.add_argument("--discharge", action="append", default=[], help="Substring patterns identifying discharge claims")
    ap.add_argument("--strict", action="store_true", help="Exit non-zero if any item surfaces")
    args = ap.parse_args(argv)

    paths = [Path(p).resolve() for p in args.paths]
    bn_files = _collect_bn_files(paths)
    if not bn_files:
        print(f"burhan-revisit: no .bn files found", file=sys.stderr)
        return 2

    # Concatenate + evaluate
    sources_concat = []
    file_sources: dict[Path, str] = {}
    for f in sorted(bn_files):
        text = f.read_text(encoding="utf-8")
        file_sources[f] = text
        sources_concat.append(text if text.endswith("\n") else text + "\n")
    combined = "".join(sources_concat)

    # Names appearing inside falsified_when clauses are exempt from MOVE/REMOVE
    # — they're falsifier-binders by convention, not orphan facts.
    falsifier_referenced = _falsifier_referenced_names(combined)

    # theorem-references: theorem NAME → {identifiers referenced in proves clause}
    # so the closure walker can follow claim → theorem → claim chains.
    theorem_refs = _theorem_references(combined)

    try:
        program = parse_program(combined)
        evaluator = Evaluator()
        cells = evaluator.evaluate_program(program)
    except Exception as e:
        print(f"burhan-revisit: evaluator-error: {e}", file=sys.stderr)
        return 3

    # Per-file claim-line index
    per_file_claims: dict[Path, dict[str, int]] = {
        f: _claim_lines(text) for f, text in file_sources.items()
    }

    claims_info: dict[str, dict] = {}
    for name, cell in cells.items():
        file_match: Path | None = None
        line_match = 0
        for f, claim_lines in per_file_claims.items():
            if name in claim_lines:
                file_match = f
                line_match = claim_lines[name]
                break
        claims_info[name] = {
            "file": str(file_match) if file_match else None,
            "line": line_match,
            "confidence": float(cell.confidence),
            "derivation": list(cell.derivation),
            "status": cell.status,
            "falsifier": cell.falsifier,
            "payload_repr": repr(cell.payload)[:120],
        }

    # Discharge set
    discharge_patterns = args.discharge or ["ships", "v1", "v2", "discharge"]
    discharges = {
        name for name in claims_info
        if any(p.lower() in name.lower() for p in discharge_patterns)
    }
    # Fallback: if no discharge matched, use leaf claims (claims not cited by
    # any other claim and not referenced from any theorem). Otherwise the
    # REMOVE heuristic flags every claim as orphaned.
    if not discharges:
        cited_anywhere: set[str] = set()
        for info in claims_info.values():
            for d in info["derivation"]:
                cited_anywhere.add(d.replace("cite:", ""))
        for refs in theorem_refs.values():
            cited_anywhere |= refs
        discharges = set(claims_info) - cited_anywhere

    # Transitive cite-closure of discharges. Walks both:
    #   1. claim → claim via the claim's `derivation` list
    #   2. claim → theorem → claim via theorem `proves` clause references
    @functools.lru_cache(maxsize=None)
    def closure(name: str, _ancestors: tuple[str, ...] = ()) -> frozenset[str]:
        if name in _ancestors:
            return frozenset()
        out: set[str] = set()
        if name in claims_info:
            out.add(name)
            info = claims_info[name]
            deps = [d.replace("cite:", "") for d in info["derivation"]]
            for dep in deps:
                out |= closure(dep, _ancestors + (name,))
        # If `name` is a theorem (not a claim), follow its proves-references.
        if name in theorem_refs:
            for ref in theorem_refs[name]:
                if ref in claims_info or ref in theorem_refs:
                    out |= closure(ref, _ancestors + (name,))
        return frozenset(out)

    cited_by_discharge: set[str] = set()
    for d in discharges:
        cited_by_discharge |= closure(d)

    # Heuristics
    actions: dict[str, list[dict]] = {
        "EXPLORE": [],
        "MOVE": [],
        "DISSECT": [],
        "MERGE": [],
        "REMOVE": [],
        # CONVERGE: load-bearing claim has ≥2 fact-files supporting it
        # with no inter-citation chain → ceiling can be auto-lifted.
        # CAP: load-bearing claim has only ONE fact-file supporting it
        # → ceiling should be capped pending second witness.
        # Atom 0019 (convergence-without-contact-lifts-confidence).
        "CONVERGE": [],
        "CAP": [],
    }

    for name, info in claims_info.items():
        # EXPLORE — load-bearing weak link.
        # A claim's confidence < floor matters if the claim is in a discharge's
        # cite-closure (i.e., a discharge depends on it). Unmoored low-confidence
        # claims that are NOT in any closure are flagged by REMOVE instead.
        if (
            info["confidence"] < args.explore_floor
            and (name in cited_by_discharge or name in discharges)
        ):
            actions["EXPLORE"].append({
                "name": name,
                "confidence": info["confidence"],
                "file": info["file"],
                "line": info["line"],
                "reason": (
                    f"@{info['confidence']:.2f} < floor {args.explore_floor}; "
                    f"load-bearing for {sum(1 for d in discharges if name in closure(d))} discharge(s)"
                ),
            })

        # MOVE — fact-shape claims outside facts/
        # (Skip claims referenced from falsified_when — those are falsifier-binders.)
        file_path = info["file"]
        source = file_sources.get(Path(file_path), "") if file_path else ""
        if (
            _is_fact_shape(info, source, name)
            and file_path
            and not _is_in_facts_dir(file_path)
            and name not in falsifier_referenced
        ):
            actions["MOVE"].append({
                "name": name,
                "file": file_path,
                "line": info["line"],
                "reason": f"fact-shape claim (literal payload, no derivation, no falsifier) outside facts/",
            })

        # DISSECT — aggregator with no value-add
        deps = [d.replace("cite:", "") for d in info["derivation"]]
        dep_confidences = [
            claims_info[d]["confidence"] for d in deps if d in claims_info
        ]
        if (
            len(dep_confidences) >= args.dissect_min_deps
            and abs(info["confidence"] - min(dep_confidences)) < 1e-6
        ):
            actions["DISSECT"].append({
                "name": name,
                "file": file_path,
                "line": info["line"],
                "reason": (
                    f"aggregates {len(dep_confidences)} deps; confidence {info['confidence']:.3f} "
                    f"== min(deps); no aggregation lift — split to expose weakest"
                ),
            })

        # REMOVE — orphaned (not in any discharge closure)
        # Exempt: claims in facts/ (terminals by design) and claims referenced
        # from falsified_when (falsifier-binders).
        if (
            name not in cited_by_discharge
            and name not in discharges
            and not _is_in_facts_dir(file_path or "")
            and name not in falsifier_referenced
        ):
            actions["REMOVE"].append({
                "name": name,
                "file": file_path,
                "line": info["line"],
                "reason": (
                    f"not in transitive cite-closure of any discharge claim "
                    f"({sorted(discharges)[:3]}{'…' if len(discharges) > 3 else ''})"
                ),
            })

    # MERGE — pairwise scan
    # Trivial payloads (True/False/short ints/short strings) are skipped for
    # text-similarity since many claims share `True`/`False`. Derivation-overlap
    # also requires both sides to have ≥2 derivations (single-cite chains pass
    # 1.0 trivially).
    def _is_trivial_payload(repr_str: str) -> bool:
        s = repr_str.strip()
        if s in {"True", "False", "None"}:
            return True
        if len(s) <= 3:
            return True
        try:
            float(s)
            return True
        except ValueError:
            pass
        if s.startswith("'") and s.endswith("'") and len(s) <= 8:
            return True
        return False

    names = sorted(claims_info)
    seen_pairs: set[frozenset[str]] = set()
    for i, n1 in enumerate(names):
        info1 = claims_info[n1]
        for n2 in names[i + 1 :]:
            pair = frozenset({n1, n2})
            if pair in seen_pairs:
                continue
            info2 = claims_info[n2]
            d1 = {d.replace("cite:", "") for d in info1["derivation"]}
            d2 = {d.replace("cite:", "") for d in info2["derivation"]}
            overlap = 0.0
            if len(d1) >= 2 and len(d2) >= 2:
                overlap = len(d1 & d2) / max(len(d1 | d2), 1)
            text_sim = 0.0
            if not (_is_trivial_payload(info1["payload_repr"])
                    or _is_trivial_payload(info2["payload_repr"])):
                text_sim = SequenceMatcher(
                    None,
                    info1["payload_repr"],
                    info2["payload_repr"],
                ).ratio()
            if overlap >= args.merge_overlap or text_sim >= args.merge_text_similarity:
                actions["MERGE"].append({
                    "name": f"{n1} ↔ {n2}",
                    "file": info1["file"],
                    "reason": (
                        f"derivation-overlap {overlap:.2f}, payload-similarity {text_sim:.2f}"
                    ),
                })
                seen_pairs.add(pair)

    # CONVERGE / CAP — atom 0019 + atoms 0005/0018 energy-transformation form.
    # For each load-bearing claim (in any discharge's closure OR a discharge
    # itself), enumerate which fact files cite it via the citation closure.
    # If multiple fact files cite the claim AND there is no inter-citation
    # chain among them, the claim has CONVERGENCE-WITHOUT-CONTACT support
    # and the ceiling can be auto-lifted via the energy-transformation
    # formula. Single-witness support → CAP at the source-tier ceiling.
    def _fact_files_supporting(claim_name: str) -> set[str]:
        """Return the set of fact files in claim_name's transitive
        derivation closure. A "fact file" is any .bn under /facts/ that
        appears in the citation graph upstream of the claim."""
        seen: set[str] = set()
        stack: list[str] = [claim_name]
        files: set[str] = set()
        while stack:
            cur = stack.pop()
            if cur in seen:
                continue
            seen.add(cur)
            info = claims_info.get(cur)
            if not info:
                continue
            f = info.get("file")
            if f and "/facts/" in f:
                files.add(f)
            for dep in info["derivation"]:
                stack.append(dep.replace("cite:", ""))
            # Follow theorem references (theorem -> claim names cited)
            for tname, refs in theorem_refs.items():
                if cur == tname:
                    for r in refs:
                        stack.append(r)
        return files

    def _independence_score(files: list[str]) -> float:
        """Compute the geometric-mean independence-score across pairs of
        supporting fact-files. Higher = more independent; 0 = same-file
        / mutual citation. Atom 0019 step 4 — measures convergence
        ENERGY before the lift conversion."""
        if len(files) < 2:
            return 0.0
        # Citation-graph independence: do any two fact-files cite each
        # other? Conservative scan: search for the file's basename
        # appearing in the others' source text.
        basenames = [Path(f).stem for f in files]
        bidir = 0
        for i, fa in enumerate(files):
            for j, fb in enumerate(files):
                if i == j: continue
                src_a = file_sources.get(Path(fa), "")
                if basenames[j] in src_a:
                    bidir += 1
        # bidir / total possible directed edges
        n = len(files)
        max_edges = n * (n - 1)
        graph_score = 1.0 - min(1.0, bidir / max(1, max_edges))
        # Methodology-axis: heuristic on filename slugs. Distinct slugs
        # (e.g. pilot-receipts vs quality-scorer-coverage vs auto-review)
        # = distinct methodology classes. Same prefix = same axis.
        # Simple proxy: count distinct first-tokens after the leading
        # NN- numeric prefix.
        method_tokens = set()
        for bn in basenames:
            # Strip leading "NN-" if present
            tok = bn.split("-", 1)
            if len(tok) > 1 and tok[0].isdigit():
                method_tokens.add(tok[1].split("-")[0])
            else:
                method_tokens.add(bn.split("-")[0])
        methodology_score = min(1.0, len(method_tokens) / len(files))
        # Geometric mean of the two sub-scores (temporal-gap requires git
        # history; deferred — current implementation skips it, contributes
        # neutral 1.0 so it doesn't artificially deflate).
        return (graph_score * methodology_score) ** 0.5

    def _structural_identity_score(claim_name: str, files: list[str]) -> float:
        """Approximate structural identity by shared DERIVATION shape.
        If the claim's payload is identical when reduced via citations,
        AND multiple files contribute receipts, identity is high.
        Conservative default: 0.7 (acknowledging this is a heuristic)."""
        info = claims_info.get(claim_name)
        if not info or not info["derivation"]:
            return 0.5
        # If the falsifier-referenced check holds AND derivation is
        # multi-witness, structural identity is plausibly load-bearing.
        if claim_name in falsifier_referenced and len(info["derivation"]) >= 2:
            return 0.85
        return 0.7

    DAMPENING = 0.5  # atom 0019 step 4 calibrated start; tighten if falsifiers fire
    AUTH_CEILING_CAP = 0.95  # M14 sahih ceiling; lift never exceeds

    converged_claims: set[str] = set()
    for name in (cited_by_discharge | discharges):
        info = claims_info.get(name)
        if not info or info["confidence"] is None:
            continue
        files = sorted(_fact_files_supporting(name))
        if len(files) < 2:
            # CAP — single-witness load-bearing claim; cap pending second witness.
            if (
                len(files) == 1
                and info["confidence"] > 0.85  # only flag if claim is at hasan+
                and not _is_in_facts_dir(info.get("file") or "")
            ):
                actions["CAP"].append({
                    "name": name,
                    "file": info.get("file"),
                    "line": info.get("line", 0),
                    "reason": (
                        f"@{info['confidence']:.2f} but supported by only ONE fact-file "
                        f"({Path(files[0]).name}); cap at @>=0.85 pending second "
                        f"independent witness OR explicit 0.78 (L4) downgrade per atom 0019"
                    ),
                })
            continue
        ind = _independence_score(files)
        struct = _structural_identity_score(name, files)
        convergence_energy = ind * struct
        ceiling_distance = max(0.0, AUTH_CEILING_CAP - info["confidence"])
        lift = round(convergence_energy * ceiling_distance * DAMPENING, 3)
        if lift < 0.005:
            continue  # below noise floor
        new_ceiling = round(min(AUTH_CEILING_CAP, info["confidence"] + lift), 3)
        if new_ceiling <= info["confidence"]:
            continue
        actions["CONVERGE"].append({
            "name": name,
            "file": info.get("file"),
            "line": info.get("line", 0),
            "reason": (
                f"@{info['confidence']:.2f} → auto-lift to @{new_ceiling:.3f} "
                f"(N={len(files)} fact-files, independence {ind:.2f} × "
                f"structural-identity {struct:.2f} × dampening {DAMPENING} × "
                f"ceiling-distance {ceiling_distance:.2f}). "
                f"Witnesses: {', '.join(Path(f).name for f in files)}"
            ),
        })
        converged_claims.add(name)

    # MAIN.md drift
    main_drift_msg = None
    if args.main and args.baseline_snapshot:
        baseline = json.loads(Path(args.baseline_snapshot).read_text(encoding="utf-8"))
        main_path = Path(args.main).resolve()
        baseline_hash = None
        for t in baseline.get("tracked_files", []):
            if Path(t["path"]).resolve() == main_path:
                baseline_hash = t["sha256"]
                break
        if baseline_hash is None:
            main_drift_msg = f"⚠ baseline snapshot did not track `{main_path}`. Re-run burhan-snapshot --track."
        elif main_path.exists():
            current_hash = _sha256(main_path)
            if current_hash != baseline_hash:
                main_drift_msg = (
                    f"⚠ MAIN.md drift detected.\n"
                    f"  baseline: `{baseline_hash[:12]}`\n"
                    f"  current:  `{current_hash[:12]}`\n"
                    f"  → re-evaluate goal-bound claims (those in {sorted(discharges)[:3]}{'…' if len(discharges) > 3 else ''}'s closure)"
                )

    # Render report
    total = sum(len(v) for v in actions.values())
    print(f"# burhan-revisit — branches needing attention\n")
    print(f"**Sources:** {len(bn_files)} .bn file(s)")
    print(f"**Claims evaluated:** {len(claims_info)}")
    print(f"**Discharges detected:** {sorted(discharges)}")
    print(f"**Items surfaced:** {total}\n")

    if main_drift_msg:
        print("## MAIN.md drift\n")
        print(main_drift_msg)
        print()

    for action_name, items in actions.items():
        if not items:
            continue
        print(f"## {action_name} ({len(items)})\n")
        for item in sorted(items, key=lambda x: x.get("name", "")):
            name = item.get("name", "?")
            file_part = item.get("file") or "?"
            line = item.get("line", 0)
            loc = f"{file_part}:{line}" if line else file_part
            print(f"- **`{name}`** — {loc}")
            print(f"  - {item['reason']}")
        print()

    if total == 0 and not main_drift_msg:
        print("_No items surfaced. Plan is currently aligned._")

    if args.strict and (total > 0 or main_drift_msg):
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
