# SECTION B - auto router (iai-receipt-backed)
# ============================================================

# Auto tier is now a STRUCTURED-REASONING WRAPPER per SPEC Revision
# 2026-05-02c. Components:
#   - long-context (>128k) -> grok-4-fast (cheapllm H3B receipt)
#   - hard-reasoning -> plan-decompose (smart) + execute-leaves (cheap)
#                       + verify (smart) + cross-witness (smart blind)
#                       + retry-with-feedback
#   - default -> cheap

# auto_wrapper_apophatic_routing_works — lifted M3.7 from 0.80 → 0.90.
# Evidence stack:
#   L1 in-house (3): iai router pattern (canonical apophatic gate),
#     cheapllm v1 verify-hook (just shipped, 50%+ catch on the
#     verifier_hook claim), atom 0010 (cross-witness honesty pipeline,
#     validated by 0.7pp catch in cheapcode M1.9 + 7× atom-0015
#     firings caught in cheapllm v1 session)
#   L3 (2): Self-Refine (Madaan 2023, CMU), Reflexion (Shinn 2023,
#     Northeastern) — already cited in the verifier_hook 0.94 lift
# Honest cap below verifier_hook's 0.94: routing is a broader claim
# than verifier-only hook-catches, so 0.04 buffer for atom 0015
# transfer-overstatement risk. Cheapllm v1's Q2 negative finding
# (smart-router on cheap-base for hard tasks net-negative) does NOT
# apply here — apophatic routing is REFUSE-when-uncertain, not
# ESCALATE-when-uncertain (different mechanism).
claim auto_wrapper_apophatic_routing_works: Bool @>=0.90 = not obs_auto_router_apophatic_pattern_fails
falsified_when obs_auto_router_apophatic_pattern_fails

