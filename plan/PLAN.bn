falsified_when obs_best_of_k_no_lift_on_hard_tasks

# Cross-MODEL verification (different model than synthesizer) catches
# errors single-model verification misses. Atom 0010 application.
# M3.7 audit (honest skip): considered for lift to 0.85 alongside
# auto_wrapper_apophatic and plan_decompose, but the SPECIFIC empirical
# comparison "cross-MODEL > same-model self-verify" lacks direct
# evidence in facts/. The cross_witness_pattern@0.90 evidence stack
# (Self-Consistency, Optimal-SC, Adaptive-TTC, Forest-of-Thought)
# measures self-consistency with same-model-different-sampling, not
# cross-model. Per atom 0015 (transfer overstated by default), the
# parent cross-witness lift does NOT transfer to the cross-MODEL
# specific claim. Holding at @>=0.80 honest. Phase 2 EXPERIMENT-1's
# Arm A pipeline IS the smallest distinguishing experiment (atom 0011)
# for this claim — when run, it provides direct cross-model evidence.
claim obs_cross_model_verification_no_lift_over_self_verify: Bool @>=0.99 = False
claim cross_model_verification_lifts_over_self_verify: Bool @>=0.80 = not obs_cross_model_verification_no_lift_over_self_verify
falsified_when obs_cross_model_verification_no_lift_over_self_verify

# Parallel execution of decomposed leaves keeps average latency below
