claim obs_living_estimator_does_not_converge_on_true_values_falsified: Bool @>=0.99 = False
claim living_conversion_factor_estimator_converges_on_true_values_as_n_grows: Bool @>=0.78 = not obs_living_estimator_does_not_converge_on_true_values_falsified
