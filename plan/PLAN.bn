claim obs_phase_1_5_tiers_dont_appear_in_model_list: Bool @>=0.99 = False
claim obs_phase_1_loc_exceeds_350: Bool @>=0.99 = False
claim phase_1_fork_and_registration_succeeds: Bool @>=0.92 = not obs_phase_1_5_tiers_dont_appear_in_model_list
falsified_when obs_phase_1_5_tiers_dont_appear_in_model_list or obs_phase_1_loc_exceeds_350

# Phase 2: auto wrapper + EXPERIMENT-1
# (obs_phase_2_experiment_1_partial removed M3.4 — was unused; PARTIAL outcome
# is a scope-narrowing per SPEC, not a claim falsifier.)
claim obs_phase_2_experiment_1_fails_all_axes: Bool @>=0.99 = False
claim phase_2_wrapper_passes_at_least_min: Bool @>=0.65 = not obs_phase_2_experiment_1_fails_all_axes
falsified_when obs_phase_2_experiment_1_fails_all_axes

# Phase 3: 4-client smoke regression
claim obs_phase_3_any_client_falsifies_propagation: Bool @>=0.99 = False
claim phase_3_4_client_smoke_passes: Bool @>=0.95 = not obs_phase_3_any_client_falsifies_propagation
falsified_when obs_phase_3_any_client_falsifies_propagation

# Phase 4: scorecard + README
claim obs_phase_4_measured_contradicts_spec_targets: Bool @>=0.99 = False
claim phase_4_scorecard_honest: Bool @>=0.93 = not obs_phase_4_measured_contradicts_spec_targets
falsified_when obs_phase_4_measured_contradicts_spec_targets

# Phase 5: ship
claim obs_phase_5_administrative_failure: Bool @>=0.99 = False
claim phase_5_shipped: Bool @>=0.98 = not obs_phase_5_administrative_failure
falsified_when obs_phase_5_administrative_failure

# Project-level halts (independent of phase)
claim obs_project_wall_clock_22h_phase_2_not_started: Bool @>=0.99 = False
claim obs_project_cumulative_spend_9_before_phase_4: Bool @>=0.99 = False
claim obs_project_upstream_provider_arch_changed: Bool @>=0.99 = False
claim project_no_halt_condition_triggered: Bool @>=0.92 = not obs_project_wall_clock_22h_phase_2_not_started
falsified_when obs_project_wall_clock_22h_phase_2_not_started or obs_project_cumulative_spend_9_before_phase_4 or obs_project_upstream_provider_arch_changed

# ============================================================
# SECTION W - v1 ships discharge (M3.4 — added per burhan-revisit findings)
#
# Per MAIN.md: v1 = "5 tiers shipped + auto-wrapper that beats raw GPT-5.5
# on multistep reasoning." v1 IS the primary product; v2 / v3 are
# alternate proof-shapes that ADD competitive-comparison or umbrella-
# grounding on top of v1.
#
# The phase_0..5 claims represent each phase's success gate per SPEC
# Revision 2026-05-02f. Without a discharge that composes them, they
# look orphaned to burhan-revisit (REMOVE flag). This theorem ties them
# together as the load-bearing v1-shipping claim.
#
# smart_fast_tier_choice_pending_measurement is included here (5-tier
# registration is what Phase 1 ships) — was orphaned in M3.3's revisit
# because the v2 theorem only assumes the 4 simpler tiers.
#
# Confidence: cheapcode_v1_ships @>=0.45 — joint of phase claims is
# bounded by phase_2 (0.65, the experimental phase). Honest forward-
# looking estimate; will lift as phases complete (Phase 0 + 1 already
# closed at M2.0 + M3.0).
# ============================================================

theorem cheapcode_v1_ships_via_phase_completion
  assume phase_0_research_lock_holds and phase_1_fork_and_registration_succeeds and phase_2_wrapper_passes_at_least_min and phase_3_4_client_smoke_passes and phase_4_scorecard_honest and phase_5_shipped and project_no_halt_condition_triggered and smart_fast_tier_choice_pending_measurement
  proves True
  by audit cheapcode-v1-ship-discharge

claim cheapcode_v1_ships: Bool @>=0.45 = cite cheapcode_v1_ships_via_phase_completion
falsified_when obs_phase_0_research_falsifies_umbrella or obs_phase_1_5_tiers_dont_appear_in_model_list or obs_phase_2_experiment_1_fails_all_axes or obs_phase_3_any_client_falsifies_propagation or obs_phase_4_measured_contradicts_spec_targets or obs_phase_5_administrative_failure or obs_project_wall_clock_22h_phase_2_not_started
