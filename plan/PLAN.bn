# cheapcode - burhan-shape plan (Revision 2026-05-02b)
#
# Pivoted plan after operator clarification: cheapllm is a wrapper around
# OpenRouter, so cheapcode bakes five tier-shaped synthetic models
# (cheap, cheap-fast, smart, smart-fast, auto) directly into opencode's
# provider registry rather than wrapping cheapllm as a separate process.
#
# Knowledge transfer: cheapllm's L1 receipts back the per-tier OR model
# choices; iai's router design backs the auto-router pattern (~80 LoC,
# apophatic-routing as first-class).
#
# Confidence levels (per burhan README + mizaj rule 01):
#   @>=0.95  L1 own-measurement receipt (cheapllm + iai)
#   @>=0.85  L1 measurable on demand (just hasn't been run yet)
#   @>=0.75  L3 transfer from cheapllm/iai with strong illah
#   @>=0.50  speculative; must measure before commit

# ============================================================
# SECTION O - observation claims (defaults False = thesis holds)
# ============================================================

# Per-tier OR model receipt observations
claim obs_cheap_tier_or_model_unmeasured: Bool @>=0.99 = False
claim obs_cheap_fast_tier_or_model_unmeasured: Bool @>=0.99 = False
claim obs_smart_tier_or_model_unmeasured: Bool @>=0.99 = False
claim obs_smart_fast_tier_or_model_unmeasured: Bool @>=0.99 = False
claim obs_auto_router_apophatic_pattern_fails: Bool @>=0.99 = False
claim obs_long_context_grok_4_fast_unmeasured: Bool @>=0.99 = False

# Architecture observations
claim obs_propagation_at_provider_registry_layer1_fails: Bool @>=0.99 = False
claim obs_or_provider_inheritance_breaks_clients: Bool @>=0.99 = False
claim obs_surgical_fork_loc_budget_breached: Bool @>=0.99 = False
claim obs_upstream_files_modified_gt_2: Bool @>=0.99 = False

# Competitive observations
claim obs_cheapcode_beats_codex_falsified: Bool @>=0.99 = False
claim obs_cheapcode_beats_vanilla_opencode_falsified: Bool @>=0.99 = False

# Maintainability observations
claim obs_weekly_rebase_breaks: Bool @>=0.99 = False

# ============================================================
# SECTION A - per-tier OR model choices (cheapllm-receipt-backed)
# ============================================================

# cheap = deepseek-v4-flash (cheapllm Phase 0 + F-E1; $0.0032/task)
claim cheap_tier_uses_deepseek_v4_flash: Bool @>=0.95 = not obs_cheap_tier_or_model_unmeasured
falsified_when obs_cheap_tier_or_model_unmeasured

# cheap-fast = cheapllm v1 race-K strategy (deepseek + flash-lite, no router)
# Receipt: cheapllm v1 P50 2.24s; 56x cheaper than GPT-5.5
claim cheap_fast_uses_race_k_cheapllm_strategy: Bool @>=0.90 = not obs_cheap_fast_tier_or_model_unmeasured
falsified_when obs_cheap_fast_tier_or_model_unmeasured

# smart = gpt-5-mini DIRECT (no router-pretend on cheap base)
# Per atom 0013: honest niche disclosure IS the credential.
# cheapllm v1 H6 Q3-A measured cheapllm-smart's router-on-cheap-base
# at 11.1% on TB-medium/hard - under-performs gpt-5.5 at 82%. cheapcode
# refuses to replicate that pretense.
claim smart_tier_routes_directly_to_capable_model: Bool @>=0.92 = not obs_smart_tier_or_model_unmeasured
falsified_when obs_smart_tier_or_model_unmeasured

# smart-fast = haiku-4.5 or gpt-5-nano; pre-registered "fast sacrifices
# intelligence, not cost" per operator instruction
claim smart_fast_tier_choice_pending_measurement: Bool @>=0.50 = not obs_smart_fast_tier_or_model_unmeasured
falsified_when obs_smart_fast_tier_or_model_unmeasured

# Long-context override: >128k tokens routes to grok-4-fast (cheapllm H3B receipt)
claim long_context_uses_grok_4_fast: Bool @>=0.95 = not obs_long_context_grok_4_fast_unmeasured
falsified_when obs_long_context_grok_4_fast_unmeasured

# ============================================================
# SECTION B - auto router (iai-receipt-backed)
# ============================================================

# Apophatic routing per iai + cheapllm v1 task-type detection:
# - long-context (>128k) -> grok-4-fast (cheapllm H3B receipt)
# - hard-reasoning detected -> smart-tier direct (no cheap-base pretense)
# - default -> cheap-tier
claim auto_router_apophatic_pattern_works: Bool @>=0.80 = not obs_auto_router_apophatic_pattern_fails
falsified_when obs_auto_router_apophatic_pattern_fails

# Honest-niche claim per atom 0013: cheapcode's competitive credibility
# rests on transparent niche dominance, not weakly-best-overall pretense.
# cheapllm v1 H6 Q3-A established the niche; cheapcode inherits.
claim honest_niche_dominance_over_weakly_best_overall: Bool @>=0.90 = not obs_smart_tier_or_model_unmeasured
falsified_when obs_smart_tier_or_model_unmeasured

# ============================================================
# SECTION C - propagation thesis (single-file change, server-registry layer)
# ============================================================

# Adding 5 tier models to provider.ts registry propagates to all clients
# (CLI, TUI, web, desktop) because all of them read the unchanged
# provider catalog endpoint.
claim provider_registry_propagation_holds: Bool @>=0.85 = not obs_propagation_at_provider_registry_layer1_fails
falsified_when obs_propagation_at_provider_registry_layer1_fails

claim or_provider_inheritance_safe: Bool @>=0.90 = not obs_or_provider_inheritance_breaks_clients
falsified_when obs_or_provider_inheritance_breaks_clients

# ============================================================
# SECTION D - surgical-fork discipline
# ============================================================

# Per SPEC Revision 2026-05-02b cells #14-#17:
# MIN <=200 LoC maintained, <=1 upstream file modified, 0 new packages,
# 0 cross-process protocols.
claim surgical_fork_loc_budget_holds: Bool @>=0.85 = not obs_surgical_fork_loc_budget_breached
falsified_when obs_surgical_fork_loc_budget_breached

claim upstream_files_modified_within_budget: Bool @>=0.90 = not obs_upstream_files_modified_gt_2
falsified_when obs_upstream_files_modified_gt_2

claim weekly_rebase_holds: Bool @>=0.80 = not obs_weekly_rebase_breaks
falsified_when obs_weekly_rebase_breaks

# ============================================================
# SECTION E - competitive comparison (now narrower)
# ============================================================

# Vs Codex: vendor pricing fetch lifts to L2 ceiling
claim cheapcode_beats_codex_after_pricing_fetch: Bool @>=0.75 = not obs_cheapcode_beats_codex_falsified
falsified_when obs_cheapcode_beats_codex_falsified

# Vs vanilla opencode: L1-measurable cheap (run vanilla against cheapbench
# with the same OR backend, our cheapcode against same backend with our
# 5-tier defaults active). Should win on cost+latency by routing alone.
claim cheapcode_beats_vanilla_opencode_via_routing: Bool @>=0.85 = not obs_cheapcode_beats_vanilla_opencode_falsified
falsified_when obs_cheapcode_beats_vanilla_opencode_falsified

# ============================================================
# SECTION I - cited evidence anchors (substrate L1)
# ============================================================

claim cheapllm_receipts_anchor: Bool @>=0.99 = cite cheapllm_per_task_cost_0032_on_tb_easy
claim cheapllm_context_anchor: Bool @>=0.99 = cite cheapllm_niah_2m_pass_grok_4_fast
claim iai_router_pattern_anchor: Bool @>=0.99 = cite atom_0011_smallest_distinguishing_experiment_first
claim transfer_overstated_anchor: Bool @>=0.99 = cite atom_0015_research_pipeline_overstates_base_model_specific_transfer
claim mizaj_substrate_anchor: Bool @>=0.99 = cite mizaj_15_consult_atom_before_reinventing
claim khatim_negative_knowledge_anchor: Bool @>=0.99 = cite khatim_1152_ts_tsx_files_in_packages

# ============================================================
# SECTION F - composed theorems
# ============================================================

theorem cheapcode_v2_is_surgical_and_inherits_cheapllm_receipts
  assume cheap_tier_uses_deepseek_v4_flash and cheap_fast_uses_race_k_cheapllm_strategy and smart_tier_routes_directly_to_capable_model and long_context_uses_grok_4_fast and auto_router_apophatic_pattern_works and honest_niche_dominance_over_weakly_best_overall and provider_registry_propagation_holds and or_provider_inheritance_safe and surgical_fork_loc_budget_holds and upstream_files_modified_within_budget and weekly_rebase_holds and cheapllm_receipts_anchor and cheapllm_context_anchor and iai_router_pattern_anchor and transfer_overstated_anchor and mizaj_substrate_anchor and khatim_negative_knowledge_anchor
  proves True
  by audit cheapcode-v2-surgical-architecture

# Intermediate claim - burhan can only cite theorems from claim cells,
# not from another theorem's assumption directly. This claim materializes
# the surgical-architecture theorem's verdict for re-citation.
claim cheapcode_v2_surgical_architecture_audited: Bool @>=0.85 = cite cheapcode_v2_is_surgical_and_inherits_cheapllm_receipts

theorem cheapcode_v2_outperforms_named_alternatives
  assume cheapcode_v2_surgical_architecture_audited and cheapcode_beats_codex_after_pricing_fetch and cheapcode_beats_vanilla_opencode_via_routing
  proves True
  by audit competitive-scorecard

# ============================================================
# SECTION G - top-level discharge claim
# ============================================================

# Confidence target: per MAIN.md option-pick-pending. Realistic ceiling
# under composition: joint = product of correlated-group minimums. With
# the smaller claim set + cheapllm-receipt backing, joint should reach
# @>=0.40-0.55 with measurement (vs ~0.46 cap on the old 22-claim plan).
# tools/joint-confidence.ts re-runs the math.

claim cheapcode_v2_ships: Bool @>=0.45 = cite cheapcode_v2_outperforms_named_alternatives
falsified_when obs_cheap_fast_tier_or_model_unmeasured or obs_smart_fast_tier_or_model_unmeasured or obs_auto_router_apophatic_pattern_fails or obs_propagation_at_provider_registry_layer1_fails
