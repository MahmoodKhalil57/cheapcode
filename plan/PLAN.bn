claim obs_very_high_confidence_0_95_achievable_from_single_battery_falsified: Bool @>=0.99 = True
claim very_high_confidence_0_95_for_general_agent_for_human_tasks_achievable_from_single_battery: Bool @>=0.05 = not obs_very_high_confidence_0_95_achievable_from_single_battery_falsified
