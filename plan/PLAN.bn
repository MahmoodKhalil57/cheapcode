# ============================================================
# SECTION LL - M3.42 multistep-narrowed framing pre-registration
# (SUPERSEDED 2026-05-03 by SECTION MM — operator reframe pre-experiment)
#
# Operator question (2026-05-03): "what about 'MUCH more intelligent
# UNIFORMLY across multistep hard reasoning'" — narrowing M3.40's killed
# "uniform across all hard reasoning" framing.
#
# SUPERSEDE NOTE: operator (same date) further reframed: "instead of
# centering around 'uniform hard problems' can we change our burhan to
# center our 'most practical hard problems to humans' (which in itself
# is a hard problem)". SECTION MM operationalizes the practical framing
# with a 3-criterion definition + 3-tier corpus. Atom 0013 keeps LL
# visible as audit trail; atom 0011 (cheapest course-correction is
# pre-experiment) supports the reframe before any LL spend was committed.
# Compounding-error structural-mechanism claim from LL transfers to MM.
#
# STRUCTURAL ARGUMENT (why narrowing is principled, not gerrymandering):
#
# Single-step hard reasoning (M3.40 Pell mod-7, orthog-tetra) is one
# decision-gate: frontier either knows the trick OR doesn't. M3.40
# observed gpt-5 knows ~100% of these → ties. Voter has no extra
# decision-gates to catch errors at.
#
# Multistep hard reasoning has k decision-gates. Per-step independent
# error p compounds: trajectory-error = 1-(1-p)^k. Voter's per-step
# catch-rate (~70% per atom 0010 panel evidence) similarly compounds
# along the trajectory. Gap between voter and frontier should *widen*
# with k. This is the structural 'illah for the narrowed claim.
#
# COUNTER (why "uniformly" still likely fails):
# 1. gpt-5 / o-series already do internal multistep + self-verification
#    (M3.40 gpt-5 ran 67.9s on AIME-II-12). Voter's marginal lift over
#    a reflection-enabled frontier is smaller than over naive single-pass.
# 2. "Uniformly" requires ~near-100% trajectory-level lift, not 60-70%.
#    Atom 0015 will fire honestly on partial-coverage like M3.40.
# 3. Existing N=7 paired evidence is mostly k≤2 (proofs/derivations).
#    Zero k≥5 paired data to anchor the structural argument empirically.
#
# Pre-registration shape per atom 0011 + atom 0013 (calibration-as-credential):
# - claim is HONEST PRIOR, not yet observed
# - falsification criterion is PRE-COMMITTED (atom 0007 anti-fab)
# - failed predictions stay visible permanently per atom 0013
# ============================================================

# Pre-registered narrowed claim (operator-named): voter is much more
# intelligent UNIFORMLY across multistep hard reasoning. Honest prior is
# DAIF band — atom 0015 already fired twice this round on similar
# overclaims, and "uniformly" is a near-100% bar.
claim obs_voter_not_much_more_intelligent_uniformly_on_multistep_hard_reasoning_falsified: Bool @>=0.99 = False
claim voter_much_more_intelligent_uniformly_on_multistep_hard_reasoning: Bool @>=0.30 = not obs_voter_not_much_more_intelligent_uniformly_on_multistep_hard_reasoning_falsified
falsified_when obs_voter_not_much_more_intelligent_uniformly_on_multistep_hard_reasoning_falsified

# Backup-claim (drop the load-bearing word "uniformly"): voter is much
# more intelligent ON AVERAGE across multistep hard reasoning. Higher
# prior because atom 0015 doesn't fire on average-class claims.
claim obs_voter_not_much_more_intelligent_on_average_on_multistep_hard_reasoning_falsified: Bool @>=0.99 = False
claim voter_much_more_intelligent_on_average_across_multistep_hard_reasoning: Bool @>=0.62 = not obs_voter_not_much_more_intelligent_on_average_on_multistep_hard_reasoning_falsified
falsified_when obs_voter_not_much_more_intelligent_on_average_on_multistep_hard_reasoning_falsified

# Structural-mechanism claim — the compounding-error argument is the
# 'illah for why multistep should differ from single-step. Independent
# of empirical N=6 firing; supported by elementary probability + by
# facts/14 mutawatir on test-time-compute scaling laws.
claim obs_compounding_error_mechanism_does_not_apply_to_multistep_falsified: Bool @>=0.99 = False
claim multistep_compounding_error_makes_voter_lift_widen_with_k: Bool @>=0.78 = not obs_compounding_error_mechanism_does_not_apply_to_multistep_falsified
falsified_when obs_compounding_error_mechanism_does_not_apply_to_multistep_falsified

# Pre-registered falsification protocol for M3.42:
# - N=6 paired tasks where each has explicitly k≥5 reasoning steps
#   (multi-stage AIME constructions, multi-hop logic, multi-step proofs
#   with explicit intermediate checkpoints).
# - Each task run via direct gpt-5 AND cheapcode-witness v1x voter.
# - SCORE: trajectory-correctness (final answer correct AND no fabricated
#   intermediate lemma — atom 0007 anti-fab applied to the chain).
# - LIFT criterion (uniform): voter strictly more correct on ≥5/6 AND no
#   regression on remaining task → uniform claim lifts to sub-floor (0.78).
# - LIFT criterion (average): voter strictly more correct on ≥3/6 AND
#   tied or better on rest, with mean-correctness gap ≥20pp → average
#   claim lifts to sub-floor (0.78) or sahih (0.85) depending on margin.
# - FALSIFY criterion: voter wins ≤1/6 OR voter loses ≥1/6 → uniform
#   claim drops below daif (≤0.20) AND atom 0015 fires on operator-implied
#   framing.
# - Cost cap: $0.60 (atom 0011 budget envelope; per M3.40 calibration ~$0.10/task).
claim obs_m3_42_pre_registration_protocol_not_falsification_load_bearing: Bool @>=0.99 = False
claim m3_42_protocol_is_pre_registered_with_explicit_lift_and_falsify_criteria: Bool @>=0.95 = not obs_m3_42_pre_registration_protocol_not_falsification_load_bearing
falsified_when obs_m3_42_pre_registration_protocol_not_falsification_load_bearing

# Honest budget claim — M3.42 is structurally cheap because k≥5 tasks
# already exist in AIME / Putnam / olympiad corpora and per-task cost
# was $0.025 voter / $0.022 frontier in M3.40.
claim obs_m3_42_will_exceed_budget_envelope_falsified: Bool @>=0.99 = False
claim m3_42_estimated_cost_at_or_below_60_cents_for_n_6_paired_multistep: Bool @>=0.85 = not obs_m3_42_will_exceed_budget_envelope_falsified
falsified_when obs_m3_42_will_exceed_budget_envelope_falsified

# ============================================================
# SECTION MM - M3.43 practical-hard-problems reframe (2026-05-03)
#
# Operator directive: "instead of centering around 'uniform hard
# problems' can we change our burhan to center our 'most practical hard
# problems to humans' (which in itself is a hard problem)".
#
# WHY THIS IS SHARPER (and not gerrymandering):
# 1. Aligns with MAIN.md goal — "full mix of tasks an agent encounters"
#    was always closer to "practical" than "contest-math uniform."
# 2. Substrate pattern-fit — cross-witness consensus + atom 0007 anti-fab
#    match practical messy reasoning (code review, architecture, research
#    synthesis, debugging) where multiple lenses converge. They add little
#    on single-step formula recall (frontier already nails it; M3.40 evidence).
# 3. Underweighted prior evidence — M3.36 SWE-bench 6/6 perfect at $0.094
#    was already a practical-class win; "agentic-correctness on SWE-shape"
#    was a narrower frame than "voter is the right shape for practical
#    hard problems." Reweighting to practical lifts existing evidence.
#
# META-CIRCULARITY (operator-acknowledged):
# Defining "most practical hard problems to humans" is itself hard.
# Per atom 0017 (unknowns-as-positive-data), the unknown becomes
# structural input via pre-registered 3-criterion + 3-tier corpus.
#
# 3-CRITERION DEFINITION OF PRACTICAL HARD:
#   (P1) Real-world economic value — a human or business pays (or would
#        pay) money for a correct answer. Excludes contest math, puzzles
#        without applied use.
#   (P2) Multistep — k≥3 reasoning steps with intermediate decisions.
#        Compounding-error mechanism from SECTION LL applies.
#   (P3) Multiple failure modes — not one canonical right answer; multiple
#        ways to be wrong, with asymmetric loss (one missed risk in a
#        contract worse than one missed AIME answer).
#
# 3-TIER CORPUS (pre-registered, sampled in order):
#   (T1) Published professional benchmarks: SWE-bench Verified (M3.36
#        anchor; software engineering), GPQA Diamond (graduate-level
#        science), MMLU-Pro (mixed professional knowledge), HLE-subset
#        (hard real-world Q&A).
#   (T2) Operator-revealed-preference tasks: nizam-vanilla orchestration
#        problems, AAPI corpus disambiguation, debugging real codebases,
#        research synthesis across domains. Drawn from operator's actual
#        AI-assisted work (memory anchors).
#   (T3) Economic-stakes scenarios: legal-contract risk identification,
#        medical-differential-diagnosis vignettes, financial-compliance
#        review, security-incident triage. Vignettes constructed from
#        public professional examination items.
#
# Atom 0015 anti-confirmation-bias guard: "most" requires majority-firing
# across ALL THREE tiers, not just the cheapest tier (T1). Failure on
# any one tier disqualifies "most practical" framing.
# ============================================================

# Headline reframe claim — voter is much more intelligent on most
# practical hard problems for humans. Higher prior than the multistep-
# uniform claim (LL @0.30) because (a) pattern-fit is better, (b) M3.36
# already gives partial T1 evidence, (c) "most" is softer than "uniformly."
# Honest sub-floor prior @0.55.
claim obs_voter_not_much_more_intelligent_on_most_practical_hard_problems_falsified: Bool @>=0.99 = False
claim voter_much_more_intelligent_on_most_practical_hard_problems_for_humans: Bool @>=0.55 = not obs_voter_not_much_more_intelligent_on_most_practical_hard_problems_falsified
falsified_when obs_voter_not_much_more_intelligent_on_most_practical_hard_problems_falsified

# Definitional load-bearing claim — the 3-criterion + 3-tier framing
# captures what humans MEAN by "practical hard problems" without
# gerrymandering. Falsifier: a class of clearly-practical hard problems
# (per consensus) that fails all 3 criteria, OR a class clearly NOT
# practical that passes all 3.
claim obs_3_criterion_3_tier_practical_definition_gerrymanders_or_misses_canonical_class_falsified: Bool @>=0.99 = False
claim practical_hard_problems_well_defined_via_3_criterion_and_3_tier_corpus: Bool @>=0.70 = not obs_3_criterion_3_tier_practical_definition_gerrymanders_or_misses_canonical_class_falsified
falsified_when obs_3_criterion_3_tier_practical_definition_gerrymanders_or_misses_canonical_class_falsified

# Reweight existing M3.36 evidence under new framing — SWE-bench
# Verified is canonical T1 corpus. 6/6 perfect at $0.094 on N=2 was
# UNDERWEIGHTED as "agentic-correctness on SWE-shape" @0.62; under the
# practical framing it lifts to "T1 partial-anchor for practical claim"
# at hasan band. Atom 0017 byproduct-cycle: existing data, new framing,
# $0 marginal cost.
claim obs_m3_36_swe_evidence_does_not_anchor_practical_claim_at_t1_falsified: Bool @>=0.99 = False
claim m3_36_swe_6_of_6_perfect_anchors_practical_claim_at_t1_partial_hasan: Bool @>=0.72 = not obs_m3_36_swe_evidence_does_not_anchor_practical_claim_at_t1_falsified
falsified_when obs_m3_36_swe_evidence_does_not_anchor_practical_claim_at_t1_falsified

# Structural-mechanism claim from LL transfers to MM — compounding error
# applies just as much (more, plausibly) on practical multistep tasks.
# Plus practical tasks have ASYMMETRIC LOSS, where voter's catch-rate
# value is amplified vs benchmark-correctness.
claim obs_practical_tasks_do_not_have_asymmetric_loss_amplifying_voter_value_falsified: Bool @>=0.99 = False
claim practical_hard_problems_have_asymmetric_loss_amplifying_voter_catch_value_beyond_benchmark_correctness: Bool @>=0.78 = not obs_practical_tasks_do_not_have_asymmetric_loss_amplifying_voter_value_falsified
falsified_when obs_practical_tasks_do_not_have_asymmetric_loss_amplifying_voter_value_falsified

# Pre-registered M3.43 protocol:
# - N=9 paired tasks (3 per tier): 3× T1 (SWE-bench Verified extension +
#   GPQA Diamond + MMLU-Pro hard-shaped), 3× T2 (operator-revealed: real
#   debugging + AAPI corpus disambiguation + cross-domain research
#   synthesis), 3× T3 (economic-stakes vignette: legal/medical/security).
# - Each task run via direct gpt-5 AND cheapcode-witness v1x voter.
# - SCORE: trajectory-correctness with atom 0007 anti-fab applied;
#   T2/T3 may need rubric-grading by frontier-d (Claude Sonnet 4.6) +
#   operator spot-check on 2-3 borderline cases.
# - LIFT criterion ("most practical"): voter wins ≥6/9 OVERALL AND wins
#   ≥2/3 on at LEAST 2 of 3 tiers (no zero-tier) → claim lifts to sahih
#   sub-floor (0.78).
# - SAHIH FULL criterion: voter wins ≥7/9 AND ≥2/3 on all 3 tiers AND
#   mean-correctness gap ≥25pp → claim lifts to sahih (0.85).
# - FALSIFY criterion: voter wins ≤3/9 OR loses on ≥2 tiers → claim
#   drops below daif (≤0.20) AND atom 0015 fires.
# - Cost cap: $1.00 (per M3.40 calibration ~$0.10/paired + T2/T3
#   rubric-grading overhead estimated ~$0.30 total).
claim obs_m3_43_pre_registration_protocol_not_falsification_load_bearing: Bool @>=0.99 = False
claim m3_43_protocol_pre_registered_with_9_task_3_tier_atom_0015_guard: Bool @>=0.95 = not obs_m3_43_pre_registration_protocol_not_falsification_load_bearing
falsified_when obs_m3_43_pre_registration_protocol_not_falsification_load_bearing

# Honest budget claim
claim obs_m3_43_will_exceed_one_dollar_envelope_falsified: Bool @>=0.99 = False
claim m3_43_estimated_cost_at_or_below_one_dollar_for_n_9_paired_3_tier: Bool @>=0.78 = not obs_m3_43_will_exceed_one_dollar_envelope_falsified
falsified_when obs_m3_43_will_exceed_one_dollar_envelope_falsified

# Composed practical-headline target (joint of definitional + empirical
# + reweighted prior evidence). This SUPERSEDES the
# voter_much_more_intelligent_uniformly_on_multistep_hard_reasoning
# claim from SECTION LL as the load-bearing M3.42-class headline.
theorem voter_practical_intelligence_lift_load_bearing_headline
  assume voter_much_more_intelligent_on_most_practical_hard_problems_for_humans and practical_hard_problems_well_defined_via_3_criterion_and_3_tier_corpus and m3_36_swe_6_of_6_perfect_anchors_practical_claim_at_t1_partial_hasan
