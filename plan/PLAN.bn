# Per mizaj 14: 2 L1 + 5 L3 mutawatir → @>=0.90 (capped just below
# 0.92 mixed-L1-L3 ceiling because the L3 papers measure self-
# consistency on math/code, not all hard-reasoning shapes).
claim obs_cross_witness_convergence_lt_70pct: Bool @>=0.99 = False
claim cross_witness_pattern_lifts_hard_reasoning: Bool @>=0.90 = not obs_cross_witness_convergence_lt_70pct
falsified_when obs_cross_witness_convergence_lt_70pct

# Plan-decompose-and-execute amortizes smart-tier calls.
# Lifted M3.7 from @>=0.80 → @>=0.85: Plan-and-Solve (UCLA L3) + Tree
# of Thoughts (Princeton L3) + ReAct (Yao 2023 ICLR L3, in
# facts/03 with full caveat). 3 independent L3 groups. Per mizaj 11
# L3 ceiling = 0.85; with 3 independent groups (just below mutawatir
# threshold of 5), holding at the ceiling is honest. NOT lifted past
# 0.85 because no L1 in-house measurement exists yet — Phase 2
# EXPERIMENT-1 (when run) will provide direct evidence and could lift
# further toward the post-measurement ceiling.
claim obs_plan_decompose_smart_calls_grow_linearly: Bool @>=0.99 = False
claim plan_decompose_amortizes_smart_calls: Bool @>=0.85 = not obs_plan_decompose_smart_calls_grow_linearly
falsified_when obs_plan_decompose_smart_calls_grow_linearly

# THE LOAD-BEARING 3-AXIS COMPREHENSIVE-DOMINANCE CLAIM (M1.5 lift):
# cheapcode-auto on MULTISTEP TB-medium/hard beats raw GPT-5.5 on ALL
# THREE axes simultaneously: cost <=0.30x, latency <=0.70x,
# completion >=1.10x. Single-step tasks explicitly excluded.
#
# Lifted via mizaj rule 16 from @>=0.65 to @>=0.85: 4 independent
# peer-reviewed L3 groups converging on the wrapper-beats-frontier
# mechanism — Snell ICLR 2025 "Scaling LLM Test-Time Compute Optimally"
# (compute-optimal beats 14x larger model FLOPs-matched), EMNLP 2025
# Compound AI Survey, EMNLP 2025 CAI Behavioral Eval, AlphaCode-2.
# Mutawatir-equivalent at L3 ceiling. Illah > transfer gap so no
# transfer penalty.
# Pre-registered falsifier: plan/EXPERIMENT-1.md
# M3.23 update (2026-05-03): observation flag FLIPPED to True per M3.11/M3.11b
# empirical FAIL on cost+latency (1.3-1.9× more expensive, 5× slower than
# baseline). The 3-axis-dominance claim on the COMPOUND WRAPPER is
# FALSIFIED. Atom 0015 (transfer-overstated) fired and is honestly
# recorded. The voter-pipeline claim (M3.18-M3.20) is structurally
# different — see SECTION Y for voter-specific cost/latency claims and
# SECTION Z below for voter-vs-frontier paired evidence. The wrapper-
# specific claim stays as falsified history per atom 0013 (calibration-
# as-credential disclosure: failed experiments stay visible).
