claim phase_ii_substrate_harness_integration_required_for_goal_at_20_60_dollars_plus_1_3_weeks_engineering: Bool @>=0.85 = not obs_phase_ii_substrate_harness_integration_not_required_for_goal_falsified
falsified_when obs_phase_ii_substrate_harness_integration_not_required_for_goal_falsified

