# As of M3.12 most evidence is L4 (vendor blogs + leaderboards). Per mizaj
# 11 L4 ceiling = 0.40, individual routing rules cap at @0.40 unless
# multi-source converged. Some rules with 2-3 independent sources lift
# to L4-mutawatir ~0.55. The cheapcode-own-measurement L1 anchors
# (deepseek long-context, M3.11/M3.11b experiment data) lift specific
# rules to ~0.85.
# ============================================================

# Routing-rule observation claims (default False = rule holds)
claim obs_route_long_context_falsified: Bool @>=0.99 = False
claim obs_route_agentic_swe_falsified: Bool @>=0.99 = False
claim obs_route_bounded_code_falsified: Bool @>=0.99 = False
