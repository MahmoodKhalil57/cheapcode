claim obs_phase_iii_paired_re_run_not_load_bearing_for_lift_claim_falsified: Bool @>=0.99 = False
claim phase_iii_substrate_enhanced_re_run_anchors_lift_claim_at_70_90_dollars: Bool @>=0.88 = not obs_phase_iii_paired_re_run_not_load_bearing_for_lift_claim_falsified
falsified_when obs_phase_iii_paired_re_run_not_load_bearing_for_lift_claim_falsified

