# General-agent discharge theorem
theorem cheapcode_general_agent_routes_optimally_via_failure_envelopes
  assume route_long_context_holds and route_agentic_swe_holds and route_bounded_code_holds and route_math_chain_holds and route_phd_factual_holds and route_computer_use_holds and route_multistep_no_compound_default and route_subsecond_holds and route_closed_book_holds
