claim obs_parallel_leaf_execution_no_latency_benefit: Bool @>=0.99 = False
claim parallel_leaf_execution_keeps_latency_below_raw: Bool @>=0.89 = not obs_parallel_leaf_execution_no_latency_benefit
falsified_when obs_parallel_leaf_execution_no_latency_benefit

