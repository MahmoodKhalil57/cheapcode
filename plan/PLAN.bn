# Headline-3: SWE-bench latency ≤75% of codex+gpt-5.5.
# M3.29: @0.30. M3.30 CORRECTION: @0.40 — parallel sub-task dispatch
# (where opencode loop allows) + cheap-tier on routine reduces latency;
# cross-witness adds latency on hard sub-tasks. Net depends on task mix.
# Marginal lift over M3.29 because we're not building the harness.
claim obs_cheapcode_v2x_swe_latency_above_three_quarters_codex_falsified: Bool @>=0.99 = False
claim cheapcode_v2x_swe_latency_at_most_75pct_of_codex: Bool @>=0.40 = not obs_cheapcode_v2x_swe_latency_above_three_quarters_codex_falsified
falsified_when obs_cheapcode_v2x_swe_latency_above_three_quarters_codex_falsified

# Composed agentic-frontier goal — joint of all three headline targets.
# M3.29: @0.10. M3.30 CORRECTION: @0.25 honest correlated joint.
# Independence-product: 0.35 × 0.60 × 0.40 = 0.084. Honest correlated
# joint ~0.25 since the substrate enhancements likely lift multiple axes
# together (a substrate-enhanced agent is plausibly cheaper AND more
# accurate together, less likely to win on cost but lose on completion).
theorem cheapcode_agent_beats_codex_gpt5_5_on_3_axes
  assume cheapcode_v2x_swe_completion_at_least_82pct and cheapcode_v2x_swe_cost_at_most_50pct_of_codex and cheapcode_v2x_swe_latency_at_most_75pct_of_codex
  proves True
  by audit cheapcode-agentic-frontier-goal-discharge-m3-30

claim cheapcode_agent_beats_codex_gpt5_5_on_swe_bench_verified_3_axes: Bool @>=0.32 = cite cheapcode_agent_beats_codex_gpt5_5_on_3_axes
falsified_when obs_cheapcode_v2x_swe_completion_below_82pct_falsified or obs_cheapcode_v2x_swe_cost_above_half_of_codex_falsified or obs_cheapcode_v2x_swe_latency_above_three_quarters_codex_falsified

