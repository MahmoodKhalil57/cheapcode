# "VERY HIGH confidence" (>=0.95) requires longitudinal data and is
# multi-month ongoing investment, not a single experiment battery.
claim obs_path_to_goal_does_not_exist_at_phase_i_ii_iii_for_sub_floor_to_sahih_falsified: Bool @>=0.99 = False
claim cheapcode_path_to_goal_at_sub_floor_to_sahih_via_phase_i_ii_iii_at_160_to_240_dollars_2_6_weeks: Bool @>=0.78 = not obs_path_to_goal_does_not_exist_at_phase_i_ii_iii_for_sub_floor_to_sahih_falsified
falsified_when obs_path_to_goal_does_not_exist_at_phase_i_ii_iii_for_sub_floor_to_sahih_falsified

# Honest disclosure per atom 0013: "very high confidence" >=0.95 is NOT
