# M24 default-config availability: cheapcode's synthetic tier provider must be
# available whenever the cheapcode CLI starts, even if the installer skipped an
# existing/missing split-brain config. Falsifier: with no cheapcode-isolated
# opencode.json, running the guard fails to create provider.cheapcode with all
# six tier IDs and the cheapcode-accounts MCP server, or overwrites an existing
# user-defined provider entry.
claim default_provider_self_heals_on_cli_start: Bool @>=0.90 = not obs_default_provider_self_heal_fails
falsified_when obs_default_provider_self_heal_fails

# M25 Homebrew packaging: brew installs cheapcode-owned code under the Cellar
# (via libexec) and exposes only Homebrew-managed bin wrappers. Falsifier: the
# formula writes managed source into ~/.cheapcode, mutates shell rc files, uses
# curl-pipe install logic, self-updates Cellar code outside brew, or lacks a
# zap stanza for user config/auth cleanup.
claim homebrew_formula_is_cellar_native_and_uninstall_clean: Bool @>=0.90 = not obs_homebrew_formula_not_cellar_native
falsified_when obs_homebrew_formula_not_cellar_native

# M26 vanilla-opencode-like packaging: cheapcode should build an npm-style
# package with Node-executable bins and a compiled provider export, while the
# Homebrew formula uses Node at runtime plus a compiled opencode fork binary.
# Falsifier: `bun run build:npm` fails, generated package lacks bin entries, or
# `node .release/npm/dist/bin/cheapcode.js version` fails.
claim npm_style_node_package_builds_for_homebrew: Bool @>=0.90 = not obs_npm_style_node_package_build_fails
falsified_when obs_npm_style_node_package_build_fails

