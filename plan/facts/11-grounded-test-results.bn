# plan/facts/11-grounded-test-results.bn
#
# Atomized L1 own-measurement facts from cheapcode M3.x experimental runs.
# Each lemma is an OBSERVATION: a specific outcome was recorded in
# runs/<milestone>/results.jsonl + verdict.md, committed to the repo,
# and is reproducible from the cached artifacts.
#
# Confidence: lemma form (proves True by audit) implies @0.99 — these are
# direct observations, not derived inferences. Atomization motivation per
# operator M3.37: "split current .bn files into more .bn files with pure
# 1 confidence, and then rebuild the plan up from there." Higher-level
# claims in PLAN.bn now cite these atomic facts instead of carrying their
# own narrative confidence.
#
# Statistical lineage (per Statistics.md): direct observation is the
# tier-1 grounding of all statistical inference (Babylonian grain count
# on clay tablet → modern instance: cheapcode/runs/<milestone>/results.jsonl).

# ============================================================
# M3.11 + M3.11b — compound wrapper FAIL on cost+latency
# ============================================================

# M3.11 attempt-1 (10 simple multistep tasks): wrapper 1.86× cost,
# 5.49× latency vs baseline gpt-5; both arms 100% completion (ceiling
# effect). runs/experiment-1-attempt-1/verdict.md.
lemma m3_11_wrapper_fail_cost_1_86x_latency_5_49x_completion_ceiling_l1
  proves True
  by audit cheapcode-experiment-1-attempt-1-results-jsonl-grounded

# M3.11b attempt-2 (10 hand-curated harder multistep): wrapper 1.33× cost,
# 5.13× latency; both arms 100% post-Unicode-fix (atom 0009 fired).
# Cycle-C re-mining (M3.25) found 4/10 tasks where wrapper was CHEAPER
# (h02-flight 0.88×, h04-light 0.90×, h05-combinatorics 0.72×,
# h06-cond-prob 0.94×) — bimodal distribution with hard-multistep
# amortization niche. h01-compound-percent: baseline correct, wrapper
# WRONG (atom 0013 disclosure: completion was 9/10 not 10/10).
lemma m3_11b_wrapper_avg_fail_but_4_of_10_hard_tasks_amortize_l1_per_task_grounded
  proves True
  by audit cheapcode-experiment-1-attempt-2-results-jsonl-grounded

# ============================================================
# M3.13 — AIME hang on combinatorics-symmetry shape
# ============================================================

# M3.13: M3.10 compound wrapper hung 50+ minutes on AIME-I-11
# (combinatorics-symmetry). Process killed manually. Salvaged N=3 partial
# data. Triggered M3.17 timeout fix.
lemma m3_13_wrapper_hung_50min_on_aime_i_11_combinatorics_symmetry_l1
  proves True
  by audit cheapcode-experiment-1-attempt-3-partial-results-l1

# ============================================================
# M3.19 — voter probe N=5 mixed (3 hard AIME + 2 known-impossible)
# ============================================================

# Voter probe: 4/5 correct, $0.0516, P50 60s, 8.5 min wall. Per-class:
# negative tasks 2/2 sahih (no escalation, $0.0002/task, 17s avg);
# positive tasks 0/3 sahih, all escalated (mean 158s, $0.017/task).
# runs/experiment-2-voter-probe/voter-probe-summary.json.
lemma m3_19_voter_probe_n5_mixed_4_of_5_correct_0_0516_usd_60s_p50_l1
  proves True
  by audit cheapcode-m3-19-voter-probe-summary-json-grounded

# Negation-asymmetry data point: ~85× cost asymmetry, ~9× latency
# asymmetry between negation and positive subsets. Pre-registered in
# plan/facts/10-cross-witness-runtime.bn BEFORE the probe ran.
lemma m3_19_negation_asymmetry_85x_cost_9x_latency_paired_observation_l1
  proves True
  by audit cheapcode-m3-19-voter-probe-per-class-data-grounded

# ============================================================
# M3.23 — voter vs direct GPT-5 on 3 positive AIME tasks (paired N=3)
# ============================================================

# Voter beats GPT-5 on 2 of 3 axes:
# - cost: voter $0.0512 / GPT-5 $0.0658 = 0.78× (voter cheaper)
# - completion: voter 2/3 / GPT-5 1/3 = +1 (voter higher)
# - latency: voter 184s P50 / GPT-5 131s P50 = 1.40× (voter slower)
# Per-task: AIME-I-11 both failed; AIME-I-14 GPT-5 wrong (answered 6,
# gold 104), voter caught via cheap-pair disagreement → smart_C tiebreak;
# AIME-II-13 both correct, voter half the cost.
# runs/experiment-3-voter-vs-frontier/baseline-summary.json.
lemma m3_23_voter_beats_gpt5_2_of_3_axes_n3_paired_l1
  proves True
  by audit cheapcode-m3-23-voter-vs-frontier-summary-grounded

# ============================================================
# M3.27 — cheapcode-witness v0 dogfood (N=3 knowledge synthesis)
# ============================================================

# v0 voter on Q1 disphenoid + Q2 primes-n²+1 + Q3 apophatic-traditions.
# All 3 came back graded daif due to extractAnswer regex misclassifying
# knowledge-synthesis prose. Substantively: matched single-pass Claude
# baseline, surfaced 1 citation Claude missed (Vivekacūḍāmaṇi), but did
# not strictly beat baseline.
# runs/m3-27-witness-dogfood/verdict.md.
lemma m3_27_v0_witness_matches_single_pass_claude_n3_synthesis_l1
  proves True
  by audit cheapcode-m3-27-v0-dogfood-verdict-grounded

# ============================================================
# M3.28 — cheapcode-witness v1x panel-of-experts (N=3 knowledge synthesis)
# ============================================================

# v1x (cheap × 2 + frontier-d Sonnet 4.6 + synthesizer gpt-5-mini) BEAT
# single-pass Claude on all 3 questions:
# - Q1 disphenoid: 3 distinct derivation paths + caught cheap-a's
#   discarded "/72" tentative error
# - Q2 primes n²+1: parity-problem obstruction + asymptotic-sieve attribution
#   + caught D's semiprime-vs-P2 imprecision
# - Q3 apophatic: added Jewish (Philo + Maimonides) + al-Ghazālī + flagged
#   methodological-vs-poetic Daoism distinction + Greek→Islamic transmission
#   caveat (which directly improved khazina atom 0017's credential)
# Cost $0.0448 avg per artifact. runs/m3-28-v1x-dogfood/verdict.md.
lemma m3_28_v1x_panel_beats_single_pass_claude_n3_knowledge_synthesis_0_045_per_artifact_l1
  proves True
  by audit cheapcode-m3-28-v1x-dogfood-verdict-grounded

# ============================================================
