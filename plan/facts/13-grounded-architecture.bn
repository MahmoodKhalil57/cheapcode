# plan/facts/13-grounded-architecture.bn
#
# Atomized architectural facts about cheapcode-fork ↔ opencode-upstream
# relationship + substrate-tooling structure. Each lemma is an
# operator-confirmed-and-grounded-in-repo-state fact at @0.99.
#
# Atomization motivation per operator M3.37: surface base facts at
# @0.99 so derived claims in PLAN.bn cite atomic foundations rather
# than carry their own opaque confidence.

# ============================================================
# Fork relationship (operator M3.30 correction)
# ============================================================

# cheapcode is an OPENCODE FORK that improves opencode by adding
# substrate-enhanced dispatch + routing intelligence + cross-witness
# verification. Per operator M3.30: "cheapcode is a fork of opencode
# that improves it; the substrate is the enhancement layer for the
# inherited agent harness." The agent harness is INHERITED via fork
# from upstream opencode v1.14.33.
lemma cheapcode_is_opencode_fork_atop_v1_14_33_with_substrate_enhancement_layer_l1
  proves True
  by audit cheapcode-readme-spec-claude-md-grounded-operator-confirmed-2026-05-03

# Currently zero patches applied (patches/ directory empty as of M3.30).
# v1.0 strategic position is "fork that adds value via substrate-enhanced
# provider package + tools/ runtime primitives." Strategic intent allows
# future patches when M18-disciplined (per operator M3.31).
lemma cheapcode_currently_zero_patches_to_opencode_with_strategic_fork_position_l1
  proves True
  by audit cheapcode-patches-dir-empty-readme-zero-patches-statement-grounded

# ============================================================
# Substrate primitives implemented in cheapcode-fork
# ============================================================

# 4 fork-side primitives shipped under M18 discipline:
# - src/cross-witness-voter.ts (M3.18, 259 LoC, 8 tests)
# - src/code-witness.ts (M3.32, 170 LoC, 9 tests, 100% func cov)
# - tools/reality-check.ts (M3.33, 180 LoC, 12 tests, 100% func cov)
# - tools/conversion-factors.ts (M3.34, 440 LoC, 26 tests, 93% func cov)
# Plus tools/cheapcode-witness.ts (M3.27 v0 + M3.28 v1x).
# All M18-disciplined: burhan claim FIRST + test FIRST + ~100% coverage.
lemma cheapcode_4_runtime_primitives_plus_witness_tool_m18_disciplined_84_tests_pass_l1
  proves True
  by audit cheapcode-src-tools-test-suite-2026-05-03-grounded

