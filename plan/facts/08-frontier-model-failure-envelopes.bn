# auto-tier should encode. Each one is a (task-shape → preferred-model)
# rule with a citation chain back to the per-model lemmas above.

lemma router_long_context_above_128k_use_deepseek_or_grok_fast
  proves True
  by audit cheapcode-routing-synthesis-deepseek-2m-niah-l1-plus-grok-2m-vendor-l4

lemma router_agentic_swe_pick_opus_4_7
  proves True
  by audit cheapcode-routing-synthesis-opus-mcp-atlas-77-3-l4

lemma router_closed_book_no_tool_avoid_gpt55
  proves True
  by audit cheapcode-routing-synthesis-gpt55-overconfidence-86-pct-l4

lemma router_phd_reasoning_per_dollar_pick_gemini_3_flash
  proves True
  by audit cheapcode-routing-synthesis-gemini-flash-gpqa-90-4-pct-at-1-13-l4

lemma router_math_chain_pick_deepseek_v3_2_speciale_or_v4
  proves True
  by audit cheapcode-routing-synthesis-deepseek-aime-96-pct-l4

lemma router_bounded_code_pick_haiku_4_5
  proves True
  by audit cheapcode-routing-synthesis-haiku-swebench-73-3-pct-plus-operator-empirical-memory-l1l4

lemma router_computer_use_osworld_pick_gpt54_mini
  proves True
  by audit cheapcode-routing-synthesis-gpt54-mini-osworld-72-1-pct-l4

lemma router_subsecond_p50_pick_gemini_flash_or_llama_scout
  proves True
