# ============================================================
# Routing decision-table (each rule = task-shape → model + rationale)
#
# Each rule below cites BOTH the task-shape canon AND a per-model
# envelope claim from facts/08-frontier-model-failure-envelopes.bn —
# so the burhan dependency graph traces a clean path from "router fires
# for shape X" → "shape X canon" + "model Y envelope says it dominates
# at this slice."
# ============================================================

# Rule 1: long-context >128k → DeepSeek V4 (cheap+long) or Opus 4.7
# (frontier+long). DeepSeek for cost-sensitive; Opus for retention-critical.
lemma route_long_context_to_deepseek_v4_or_opus_4_7
  proves True
  by audit cheapcode-routing-rule-1-long-context-l1-deepseek-niah-plus-l4-opus-mrcr

# Rule 2: agentic SWE loop → Claude Opus 4.7. Retry-cost dominates token-cost
# in long agentic loops; Opus's MCP-Atlas 77.3% lead is the load-bearing receipt.
lemma route_agentic_swe_to_opus_4_7
  proves True
  by audit cheapcode-routing-rule-2-agentic-swe-l4-opus-mcp-atlas

# Rule 3: bounded code synthesis → Claude Haiku 4.5. SWE-bench Verified
# 73.3% beats GPT-5.1 at $0.80/M input. Operator memory L1 confirms
# quality-equivalence on bounded code in their dispatch experiments.
lemma route_bounded_code_to_haiku_4_5
  proves True
  by audit cheapcode-routing-rule-3-bounded-code-l4-haiku-swebench-plus-operator-l1

# Rule 4: math chain (AIME / olympiad) → DeepSeek V3.2-Speciale or V4
# Pro. AIME 2026 96.0% / HMMT 95.2% at <$0.50/M output. Frontier-equivalent
# math at cheap price.
lemma route_math_chain_to_deepseek_v3_2_or_v4
  proves True
  by audit cheapcode-routing-rule-4-math-chain-l4-deepseek-aime-hmmt

# Rule 5: PhD factual reasoning → Gemini 3 Flash. GPQA-Diamond 90.4%
# at $1.13/M blended is the value optimum across all tiers.
lemma route_phd_factual_to_gemini_3_flash
  proves True
  by audit cheapcode-routing-rule-5-phd-factual-l4-gemini-flash-gpqa

# Rule 6: computer-use / OSWorld → GPT-5.4 mini. OSWorld-Verified 72.1%
# at tier-2 price. Specifically NOT GPT-5.4 nano (39%) or claude-haiku
# (no public OSWorld score; default exclude).
lemma route_computer_use_to_gpt54_mini
  proves True
  by audit cheapcode-routing-rule-6-computer-use-l4-gpt54-mini-osworld

# Rule 7: multistep general reasoning (TB-medium/hard, GSM8K-hard) —
# DEPENDS on baseline saturation. If frontier already saturates, no
# wrapper helps (M3.11 evidence). If frontier fails ≥30%, route to
# strongest available frontier (Opus 4.7 or GPT-5.5 with grounding).
# DO NOT default to compound wrapper here — M3.11 + M3.11b confirmed
# wrapper costs more + slower with no completion lift on saturated tasks.
lemma route_multistep_general_to_strongest_frontier_no_compound_default
  proves True
  by audit cheapcode-routing-rule-7-multistep-l1-experiment-1-evidence

# Rule 8: classification / extraction → Llama 4 Scout. AA Intelligence
# Index 14 — but sub-1s P50 (0.81s). Use ONLY when reasoning isn't
# needed. Cheaper alternatives have 10-30× the price.
lemma route_classification_to_llama_4_scout
  proves True
  by audit cheapcode-routing-rule-8-classification-l4-llama-scout-fast-low-int

# Rule 9: sub-2s latency required → Gemini 3 Flash (1.06s) or Llama 4
# Scout (0.81s). Frontier flagships are excluded — no flagship breaks 2s.
lemma route_subsecond_latency_excludes_flagships
  proves True
  by audit cheapcode-routing-rule-9-subsecond-l4-aa-leaderboard-latency

# Rule 10: closed-book factual (no tools allowed) → AVOID GPT-5.5.
# 86% hallucination on overconfidence benchmark when forced closed-book.
# Prefer Opus 4.7 (better calibration) or route through verifier.
lemma route_closed_book_avoid_gpt55_prefer_opus
  proves True
  by audit cheapcode-routing-rule-10-closed-book-l4-gpt55-overconfidence-plus-opus-baseline

# Rule 12 (M3.26, cycle-A-derived): specialized-formula geometry
# (disphenoid, isosceles tetrahedron, inscribed sphere/insphere/inradius/
# circumradius/circumsphere) → cross-witness voter even without AIME markers.
#
# Cycle A finding (M3.25): on AIME-I-14, GPT-5 used the WRONG disphenoid
# volume formula confidently. Its formula V = (1/12)·√(2Σp²q²−Σp⁴) fails
# sanity check on regular tetrahedron. Correct formula
# V = (1/(6√2))·√((p²+q²−r²)(p²−q²+r²)(−p²+q²+r²)) gives V = 160/3 →
# r = 20√21/63 → m+n+p = 104 (gold). Voter caught the mismatch via
# cross-witness disagreement; smart_C apparently used the correct formula.
#
# Atom 0010 runtime instance on a specialized-formula problem class. The
# class is characterized by: (a) the canonical formula is class-specific
# (not derivable from a universal formula at run-time), (b) confidence in
# the formula is high (model commits without sanity-checking), (c) cross-
# witness disagreement on the formula choice is the structural failure-
# detection signal.
#
# Falsifier per mizaj 01: paired test on N≥3 specialized-formula geometry
# problems shows voter does NOT outperform direct frontier on completion.
# Atom 0015 caveats: small N (1 firing case so far); may overstate transfer
# to non-disphenoid specialized-formula classes.
lemma route_specialized_formula_geometry_to_cross_witness_voter
  proves True
  by audit cheapcode-routing-rule-12-specialized-formula-geometry-m3-26-cycle-a

# ============================================================
# Discrimination evidence (M3.11 + M3.11b in-house L1)
#
# These are cheapcode's own L1 measurements that bound the routing
# matrix's prescriptions. Specifically: when does compound wrapping
# help, and when is single-model routing better?
# ============================================================

# L1 in-house: compound wrapper costs ~1.3-1.9× more than single
# frontier on multistep tasks across two attempts. Structural to
# compound-LLM architecture.
lemma cheapcode_compound_wrapper_costs_more_l1_2_attempts
  proves True
  by audit cheapcode-experiment-1-attempt-1-and-2-l1-receipt

# L1 in-house: compound wrapper P50 5-7× SLOWER than single frontier.
# Sequential pipeline overhead dominates regardless of difficulty.
lemma cheapcode_compound_wrapper_slower_l1_2_attempts
  proves True
  by audit cheapcode-experiment-1-attempt-1-and-2-l1-receipt

# L1 in-house: completion-rate inconclusive on saturated benchmarks.
# Smart-axis claim untested when baseline hits 100%. Routing implication:
# DO NOT default to compound wrapper — only invoke when baseline is
# known to fail on the specific task shape.
lemma cheapcode_compound_smart_axis_untested_when_baseline_saturates_l1
  proves True
  by audit cheapcode-experiment-1-attempt-1-and-2-l1-receipt

# ============================================================
# Synthesis: the auto-tier router contract
# ============================================================

# When the router fires `auto`, it should:
# 1. Classify task shape (long-context / agentic / math-chain / PhD-factual
#    / computer-use / bounded-code / classification / closed-book / general)
# 2. Look up the routing rule for that shape (rules 1-10 above)
# 3. Dispatch to the rule's preferred model
# 4. Default to compound wrapper ONLY when the task signature suggests
#    baseline will fail (e.g., novel / multi-domain / reasoning-heavy
#    where single-frontier scoring is sub-50%)
#
# This is the load-bearing claim cheapcode_general_agent_routes_optimally
# in PLAN.bn cites.

lemma router_classifier_dispatches_per_task_shape
  proves True
  by audit cheapcode-router-contract-design-decision-m3-12

lemma router_compound_wrapper_invoked_only_on_known_failure_signatures
  proves True
  by audit cheapcode-router-contract-design-decision-m3-12

# ============================================================
# Falsifiers per routing rule
#
# Each rule has a falsifier — what would make us revise it? These get
# wired into PLAN.bn's `falsified_when` clauses for the discharge claim.
# ============================================================

lemma routing_rules_falsifier_set_v1
  proves True
  by audit cheapcode-routing-falsifiers-v1-design

