// ============================================================
// Tool implementations
// ============================================================

function tool_list(): unknown {
  const explicit = listAccounts()
  const effective = loadEffectiveRegistry()
  const annotated = effective.accounts.map((a) => ({ ...a, source: classifyAccountSource(a) }))
  return {
    explicit_count: explicit.length,
    auto_discovered_count: annotated.length - explicit.length,
    total_count: annotated.length,
    registry_path: defaultRegistryPath(),
    accounts: annotated,
  }
}

function tool_show(args: Record<string, unknown>): unknown {
  const id = args.id as string
  if (typeof id !== "string") throw new Error("id required (string)")
  const account = showAccount(id)
  return { id, found: account !== null, account }
}

function tool_add(args: Record<string, unknown>): unknown {
  const account = args as unknown as Account
  const result = addAccount(account)
  if (!result.ok) throw new Error(result.error ?? "add failed")
  // Verify auth_ref resolves (informational, not required)
  let auth_resolves = false
  let auth_error: string | null = null
  try {
    resolveAuthRef(account.auth_ref)
    auth_resolves = true
  } catch (e) {
    auth_error = e instanceof AuthResolutionError ? `${e.code}: ${e.message}` : String(e)
  }
  return {
    ok: true,
    added: account.id,
    total_accounts: result.registry.accounts.length,
    auth_resolves,
    auth_error,
  }
}

function tool_remove(args: Record<string, unknown>): unknown {
  const id = args.id as string
  if (typeof id !== "string") throw new Error("id required (string)")
  const result = removeAccount(id)
  if (!result.ok) throw new Error(result.error ?? "remove failed")
  return { ok: true, removed: id, total_accounts: result.registry.accounts.length }
}

function tool_update(args: Record<string, unknown>): unknown {
  const id = args.id as string
  const updates = args.updates as Partial<Omit<Account, "id">>
  if (typeof id !== "string") throw new Error("id required (string)")
  if (updates === null || typeof updates !== "object") throw new Error("updates required (object)")
  const result = updateAccount(id, updates)
  if (!result.ok) throw new Error(result.error ?? "update failed")
  const updated = result.registry.accounts.find((a) => a.id === id)
  return { ok: true, updated_id: id, account: updated }
}

function tool_status(args: Record<string, unknown>): unknown {
  const target_model = args.target_model as string
  if (typeof target_model !== "string") throw new Error("target_model required (string)")
  const quotaOverrides = (args.quota_overrides as Record<string, number> | undefined) ?? {}
  const registry = loadEffectiveRegistry()

  const accountStatus = registry.accounts.map((a) => {
    let resolved = false
    let expired = false
    let error: string | null = null
    let account_id_from_oauth: string | null = null
    let expires_iso: string | null = null
    try {
      const auth = resolveAuthRef(a.auth_ref)
      resolved = true
      expired = isAuthExpired(auth)
      if (auth.kind === "oauth") {
        account_id_from_oauth = auth.accountId || null
        expires_iso = auth.expires === 0 ? null : new Date(auth.expires).toISOString()
      }
    } catch (e) {
      error = e instanceof AuthResolutionError ? `${e.code}: ${e.message}` : String(e)
    }
    return { id: a.id, label: a.label, provider: a.provider, priority: a.priority, resolved, expired, error, account_id_from_oauth, expires_iso }
  })

  // Resolve selection
  const unavailableIds = new Set<string>(
    accountStatus.filter((s) => s.error !== null || s.expired).map((s) => s.id),
  )
  const quotaRemaining = (acc: Account): number => quotaOverrides[acc.id] ?? 1.0
  const selection = resolveAccount(registry, {
    targetModel: target_model,
    quotaRemaining,
    unavailableIds,
  })

  return {
    target_model,
    registry_path: defaultRegistryPath(),
    account_count: registry.accounts.length,
    accounts: accountStatus,
    excluded_from_selection: [...unavailableIds],
    selected_account: selection.account?.id ?? null,
    selected_account_label: selection.account?.label ?? null,
    selection_reason: selection.reason,
  }
}

// ============================================================
// API-key add: write auth.json#{name} via opencode's PUT, then register cheapcode account
// ============================================================

async function tool_apikey_add(args: Record<string, unknown>): Promise<unknown> {
  const provider = args.provider as string
  const name = args.name as string
  const api_key = args.api_key as string
  const label = (args.label as string | undefined) ?? name
  const priority = (args.priority as number | undefined) ?? 50
  const tier = (args.tier as string | undefined) ?? "paid-per-token"
  const capabilities = (args.capabilities as string[] | undefined) ?? ["*"]

  if (!provider || !name || !api_key) throw new Error("provider, name, and api_key are required")
  if (typeof api_key !== "string" || api_key.length < 5) throw new Error("api_key looks invalid (too short)")

  // Refuse to overwrite an existing auth.json entry — we add, never silently replace
  const authPath = defaultOpencodeAuthPath()
  if (existsSync(authPath)) {
    try {
      const auth = JSON.parse(readFileSync(authPath, "utf-8")) as Record<string, unknown>
      if (name in auth) {
        throw new Error(
          `auth.json already has an entry named "${name}". Pick a different name OR remove the existing one first.`,
        )
      }
    } catch (e) {
      if ((e as Error).message.includes("already has")) throw e
      // parse error → ignore (will be handled by opencode anyway)
    }
  }

  // PUT to opencode's auth API — same endpoint the UI uses for Custom provider
  const res = await opencodeFetch(`/auth/${encodeURIComponent(name)}`, {
    method: "PUT",
    body: JSON.stringify({ type: "api", key: api_key }),
  })
  if (!res.ok) {
    const text = await res.text().catch(() => "(unreadable)")
    throw new Error(`opencode PUT /auth/${name} failed (${res.status}): ${text}`)
  }

  // Register cheapcode explicit account so this gets meaningful priority/label
  const account: Account = {
    id: name,
    label,
    provider,
    auth_type: "api-key",
    auth_ref: `~/.local/share/opencode/auth.json#${name}`,
    capabilities,
    tier: tier as never,
    priority,
  }
  const result = addAccount(account)
  if (!result.ok) {
    // auth.json was written but registry failed — surface but don't roll back
    return {
      ok: true,
      auth_written: name,
      registry_added: false,
      registry_error: result.error,
      message: `auth.json#${name} created, but cheapcode accounts.json registration failed. The account is auto-discoverable but won't have your custom priority/label until you fix the registry.`,
    }
  }
  return {
    ok: true,
    auth_written: name,
    registry_added: true,
    account_id: name,
    priority,
    message: `Account "${name}" added. opencode auth.json + cheapcode accounts.json updated. Active immediately for cheapcode/auto routing.`,
  }
}

// ============================================================
// OAuth add: trigger opencode OAuth, swap-and-rename when complete, restore primary
// ============================================================

interface OAuthEntry {
  type: string
  access?: string
  refresh?: string
  expires?: number
  accountId?: string
  [k: string]: unknown
}

function readAuthEntry(providerKey: string): OAuthEntry | null {
  const path = defaultOpencodeAuthPath()
  if (!existsSync(path)) return null
  try {
    const auth = JSON.parse(readFileSync(path, "utf-8")) as Record<string, unknown>
    return (auth[providerKey] as OAuthEntry | undefined) ?? null
  } catch {
    return null
  }
}

function authSnapshot(): Record<string, unknown> {
  const path = defaultOpencodeAuthPath()
  if (!existsSync(path)) return {}
  try {
    return JSON.parse(readFileSync(path, "utf-8")) as Record<string, unknown>
  } catch {
    return {}
  }
}

async function tool_oauth_add(args: Record<string, unknown>): Promise<unknown> {
  const provider_id = args.provider_id as string
  const name = args.name as string
  const label = (args.label as string | undefined) ?? name
  const priority = (args.priority as number | undefined) ?? 80

  if (!provider_id || !name) throw new Error("provider_id and name are required")
  if (provider_id === name) {
    throw new Error(
      `name must differ from provider_id "${provider_id}" — use something like "${provider_id}-2" or "${provider_id}-work"`,
    )
  }

  const initial = authSnapshot()
  if (name in initial) {
    throw new Error(`auth.json already has "${name}". Pick a different name.`)
  }
  const backup = (initial[provider_id] as OAuthEntry | undefined) ?? null

  // 1. Trigger opencode OAuth authorize
  const authorizeRes = await opencodeFetch(`/provider/${encodeURIComponent(provider_id)}/oauth/authorize`, {
    method: "POST",
    body: JSON.stringify({ method: 0 }),
  })
  if (!authorizeRes.ok) {
    const text = await authorizeRes.text().catch(() => "(unreadable)")
    throw new Error(
      `opencode OAuth authorize failed for ${provider_id} (${authorizeRes.status}): ${text}. ` +
      `Provider may not have OAuth methods registered.`,
    )
  }
  let authBody: { url?: string; method?: string; instructions?: string } = {}
  try {
    authBody = await authorizeRes.json() as never
  } catch {
    /* ignore */
  }
  const url = authBody.url
  if (!url) throw new Error(`opencode returned no auth URL: ${JSON.stringify(authBody)}`)

  // 2. Poll for auth.json change — wait up to ~120s for user to complete OAuth in browser
  const startMs = Date.now()
  const timeoutMs = 120_000
  const pollIntervalMs = 1500
  const initialPrimary = JSON.stringify(backup ?? {})

  let newPrimary: OAuthEntry | null = null
  while (Date.now() - startMs < timeoutMs) {
    await new Promise((resolve) => setTimeout(resolve, pollIntervalMs))
    const cur = readAuthEntry(provider_id)
    if (cur && JSON.stringify(cur) !== initialPrimary) {
      newPrimary = cur
      break
    }
  }

  if (newPrimary === null) {
    return {
      ok: false,
      timed_out: true,
      auth_url: url,
      message: `Timed out waiting for OAuth completion (120s). The auth URL is still valid — open it in incognito mode and complete authorization, then re-run this tool.`,
    }
  }

  // 3. Detect "same account" — refuse if accountId matches (user didn't switch)
  if (
    backup &&
    typeof backup.accountId === "string" &&
    typeof newPrimary.accountId === "string" &&
    backup.accountId === newPrimary.accountId &&
    backup.accountId.length > 0
  ) {
    // Restore backup so we don't leave state mutated, then error
    if (backup) {
      const restoreRes = await opencodeFetch(`/auth/${encodeURIComponent(provider_id)}`, {
        method: "PUT",
        body: JSON.stringify(backup),
      })
      if (!restoreRes.ok) {
        // Best-effort restore failed — surface
      }
    }
    throw new Error(
      `OAuth completed BUT same account (accountId=${newPrimary.accountId}) — you authorized the same user opencode already had. ` +
      `Open the auth URL in incognito/private mode (or log out of the provider first) so you authorize a DIFFERENT account, then retry. ` +
      `auth_url: ${url}`,
    )
  }

  // 4. Save the new tokens under the custom name via PUT
  const putNewRes = await opencodeFetch(`/auth/${encodeURIComponent(name)}`, {
    method: "PUT",
    body: JSON.stringify(newPrimary),
  })
  if (!putNewRes.ok) {
    throw new Error(`opencode PUT /auth/${name} failed (${putNewRes.status})`)
  }

  // 5. Restore backup under the original provider_id key
  if (backup) {
    const restoreRes = await opencodeFetch(`/auth/${encodeURIComponent(provider_id)}`, {
      method: "PUT",
      body: JSON.stringify(backup),
    })
    if (!restoreRes.ok) {
      // Best-effort — surface a warning
      return {
        ok: true,
        new_account_name: name,
        new_account_id: newPrimary.accountId ?? null,
        primary_restored: false,
        warning: `Saved new "${name}" but failed to restore primary "${provider_id}". You may need to re-OAuth your primary.`,
      }
    }
  } else {
    // No backup → user had no prior credential. Just delete the now-duplicate provider_id entry
    // since we've moved it to `name`.
    await opencodeFetch(`/auth/${encodeURIComponent(provider_id)}`, { method: "DELETE" }).catch(() => null)
  }

  // 6. Register cheapcode explicit account
  const account: Account = {
    id: name,
    label,
    provider: provider_id,
    auth_type: "consumer-oauth",
    auth_ref: `~/.local/share/opencode/auth.json#${name}`,
    capabilities: ["*"],
    tier: "subscription",
    priority,
  }
  const regResult = addAccount(account)
  return {
    ok: true,
    new_account_name: name,
    new_account_id: newPrimary.accountId ?? null,
    primary_restored: backup !== null,
    registry_added: regResult.ok,
    registry_error: regResult.ok ? null : regResult.error,
    message: `OAuth account "${name}" added (different from your existing "${provider_id}"). Both are active for cheapcode routing.`,
  }
}

const DISPATCH: Record<string, (args: Record<string, unknown>) => unknown | Promise<unknown>> = {
  cheapcode_account_list: () => tool_list(),
  cheapcode_account_show: tool_show,
  cheapcode_account_add: tool_add,
  cheapcode_account_remove: tool_remove,
  cheapcode_account_update: tool_update,
  cheapcode_account_status: tool_status,
  cheapcode_account_apikey_add: tool_apikey_add,
  cheapcode_account_oauth_add: tool_oauth_add,
}

// ============================================================
// JSON-RPC 2.0 protocol layer (matches mizan's mcp_server.py shape)
// ============================================================

interface RpcRequest {
  jsonrpc: "2.0"
  id?: number | string | null
  method: string
  params?: Record<string, unknown>
}

interface RpcResponse {
  jsonrpc: "2.0"
  id: number | string | null
  result?: unknown
  error?: { code: number; message: string }
}

function makeResponse(id: RpcRequest["id"], result: unknown): RpcResponse {
  return { jsonrpc: "2.0", id: id ?? null, result }
}

function makeError(id: RpcRequest["id"], code: number, message: string): RpcResponse {
  return { jsonrpc: "2.0", id: id ?? null, error: { code, message } }
}

function handleInitialize(id: RpcRequest["id"]): RpcResponse {
  return makeResponse(id, {
    protocolVersion: "2024-11-05",
    capabilities: { tools: {} },
    serverInfo: {
      name: "cheapcode-accounts",
      version: "1.0.0",
    },
    instructions:
      "Multi-account management for cheapcode. Use cheapcode_account_list to inspect; " +
      "cheapcode_account_add to register new account metadata (after `opencode providers " +
      "login` for OAuth); cheapcode_account_status to diagnose which account would be " +
      "selected for a given target model.",
  })
}

function handleToolsList(id: RpcRequest["id"]): RpcResponse {
  return makeResponse(id, { tools: TOOLS })
}

async function handleToolsCall(id: RpcRequest["id"], params: Record<string, unknown>): Promise<RpcResponse> {
  const name = params.name as string
  const args = (params.arguments as Record<string, unknown>) ?? {}
  if (!(name in DISPATCH)) {
    return makeError(id, -32602, `unknown tool: ${name}`)
  }
  try {
    // Tool may be sync or async — await handles both
    const result = await DISPATCH[name](args)
    return makeResponse(id, {
      content: [
        { type: "text", text: JSON.stringify(result, null, 2) },
      ],
      isError: false,
    })
  } catch (e) {
    return makeError(id, -32603, `tool ${name} raised: ${(e as Error).message}`)
  }
}

async function handleRequest(req: RpcRequest): Promise<RpcResponse | null> {
  const { method, id, params } = req
  if (method === "initialize") return handleInitialize(id)
  if (method === "initialized" || method === "notifications/initialized") return null
  if (method === "tools/list") return handleToolsList(id)
  if (method === "tools/call") return await handleToolsCall(id, params ?? {})
  // No-op handlers for MCP capabilities we don't expose. Returning empty arrays
  // (instead of method-not-found errors) is more polite to clients like opencode
  // that probe these regardless of advertised capabilities.
  if (method === "prompts/list") return makeResponse(id, { prompts: [] })
  if (method === "resources/list") return makeResponse(id, { resources: [] })
  if (method === "resources/templates/list") return makeResponse(id, { resourceTemplates: [] })
  if (method === "ping") return makeResponse(id, {})
  if (id === undefined || id === null) return null
  return makeError(id, -32601, `method not found: ${method}`)
}

// ============================================================
// stdio loop (newline-delimited JSON-RPC)
// ============================================================

async function serve(): Promise<void> {
  const decoder = new TextDecoder()
  let buffer = ""
  for await (const chunk of process.stdin) {
    buffer += decoder.decode(chunk as Uint8Array)
    const lines = buffer.split("\n")
    buffer = lines.pop() ?? ""
    for (const line of lines) {
      const trimmed = line.trim()
      if (trimmed.length === 0) continue
      let req: RpcRequest
      try {
        req = JSON.parse(trimmed)
      } catch {
        process.stdout.write(JSON.stringify(makeError(null, -32700, "parse error")) + "\n")
        continue
      }
      const response = await handleRequest(req)
      if (response !== null) {
        process.stdout.write(JSON.stringify(response) + "\n")
      }
    }
  }
}

serve().catch((e) => {
  process.stderr.write(`[cheapcode-accounts-mcp] fatal: ${(e as Error).message}\n`)
  process.exit(1)
})
