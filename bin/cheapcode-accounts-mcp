#!/usr/bin/env bun
/**
 * cheapcode-accounts-mcp — MCP server exposing multi-account management as tools.
 *
 * Stdio JSON-RPC 2.0 server, MCP spec 2024-11-05, zero deps. Same shape as
 * mizan's mcp_server.py (operator's existing pattern).
 *
 * Tools:
 *   cheapcode_account_list   — list all accounts
 *   cheapcode_account_show   — get one account by id
 *   cheapcode_account_add    — add a new account
 *   cheapcode_account_remove — remove an account by id
 *   cheapcode_account_update — partial update of fields
 *   cheapcode_account_status — diagnostic: which account would resolve for a target
 *
 * Per memory feedback_khatim_consult_protocol: this surfaces in every UI
 * that loads MCP tools (web/desktop chat panels, TUI conversation, CLI agent
 * runs). The LLM in any UI can invoke these tools naturally — no custom UI
 * shell needed. "Embraces opencode spirit" by using opencode's existing
 * MCP-server loading mechanism instead of inventing a UI surface.
 *
 * Register in ~/.config/opencode/opencode.json:
 *   "mcp": {
 *     "cheapcode-accounts": {
 *       "type": "local",
 *       "command": ["/home/mk/apps/cheapcode/bin/cheapcode-accounts-mcp"]
 *     }
 *   }
 */

import {
  addAccount,
  removeAccount,
  updateAccount,
  listAccounts,
  showAccount,
  defaultRegistryPath,
} from "../src/account-mutation"
import {
  resolveAccount,
  type Account,
} from "../src/account-registry"
import { loadEffectiveRegistry, classifyAccountSource, defaultOpencodeAuthPath } from "../src/account-discovery"
import { resolveAuthRef, isAuthExpired, AuthResolutionError } from "../src/auth-resolver"
import { readFileSync, existsSync } from "node:fs"

// ============================================================
// opencode HTTP API helpers
// ============================================================
//
// cheapcode-accounts-mcp runs as a stdio child of opencode itself. We use
// opencode's existing HTTP API for OAuth orchestration so we never reimplement
// auth flows. OPENCODE_URL env var or fall back to localhost:4096 (the port
// `cheapcode web` defaults to).

function opencodeBaseURL(): string {
  return process.env.OPENCODE_URL ?? process.env.OPENCODE_SERVER_URL ?? "http://127.0.0.1:4096"
}

async function opencodeFetch(path: string, init?: RequestInit): Promise<Response> {
  return await fetch(`${opencodeBaseURL()}${path}`, {
    ...init,
    headers: { "Content-Type": "application/json", ...(init?.headers ?? {}) },
  })
}

