#!/usr/bin/env bun
/**
 * cheapcode — unified CLI entry point (M6 of distribution-as-product trajectory).
 *
 * Telos per operator directive 2026-05-04: distribution-grade product modeled
 * after opencode.ai/download. Short-term curl-install for CLI; mid-term
 * desktop + VSCode extension. Updates when cheapcode updates, not when
 * opencode updates.
 *
 * Subcommands:
 *   web                    — start opencode web with cheapcode wired in (simple flow)
 *   tui                    — start opencode TUI with cheapcode loaded
 *   run <message...>       — non-interactive run via opencode
 *   providers <subcmd>     — manage opencode-side credentials (delegate)
 *   accounts <subcmd>      — manage cheapcode-side multi-account metadata
 *   status                 — diagnostic: registry + opencode auth resolution
 *   doctor                 — health-check: opencode installed, configs valid, MCP loaded
 *   version                — print cheapcode version
 *   update                 — re-run install script for self-update (skeleton)
 *   help                   — this text
 *
 * Embraces opencode spirit: opencode handles auth flows + UI shell; cheapcode
 * adds the multi-account metadata layer + tier dispatch wrapper.
 */

import { spawn, spawnSync } from "node:child_process"
import { existsSync, readFileSync, mkdirSync } from "node:fs"
import { homedir } from "node:os"
import { dirname, join } from "node:path"
import { fileURLToPath } from "node:url"

// ============================================================
// Version + paths
// ============================================================

const CHEAPCODE_VERSION = "0.1.0-pre" // bumped per release
const CHEAPCODE_HOME = process.env.CHEAPCODE_HOME ?? join(homedir(), ".cheapcode")
const DEFAULT_WEB_PORT = 4096

function getCheapcodeRoot(): string {
  // The repo this binary was built/run from. When installed via curl-install,
  // this is ~/.cheapcode/lib/cheapcode. During development it's the repo path.
  // fileURLToPath handles Windows file:///C:/... URLs correctly (without it,
  // the leading slash from the URL becomes an invalid path on Windows).
  const here = fileURLToPath(import.meta.url)
  let dir = dirname(here)
  while (dir !== dirname(dir)) {
    if (existsSync(join(dir, "package.json"))) {
      try {
        const pkg = JSON.parse(readFileSync(join(dir, "package.json"), "utf-8"))
        if (pkg.name === "@cheapcode/ai-sdk-provider") return dir
      } catch {
        // ignore parse errors, keep walking
      }
    }
    dir = dirname(dir)
  }
  // Fallback: assume we're at <root>/bin/cheapcode
  return dirname(dirname(here))
}

const CHEAPCODE_ROOT = getCheapcodeRoot()

// ============================================================
// Output (color codes; no emojis per CLAUDE.md)
// ============================================================

const C = {
  red: (s: string) => `\x1b[31m${s}\x1b[0m`,
  green: (s: string) => `\x1b[32m${s}\x1b[0m`,
  yellow: (s: string) => `\x1b[33m${s}\x1b[0m`,
  cyan: (s: string) => `\x1b[36m${s}\x1b[0m`,
  blue: (s: string) => `\x1b[34m${s}\x1b[0m`,
  magenta: (s: string) => `\x1b[35m${s}\x1b[0m`,
  dim: (s: string) => `\x1b[2m${s}\x1b[0m`,
  bold: (s: string) => `\x1b[1m${s}\x1b[0m`,
}

function fail(msg: string): never {
  console.error(C.red(`error: ${msg}`))
  process.exit(1)
}

// ============================================================
// Cheapcode-opencode fork resolution
// ============================================================
// Cheapcode IS a fork of opencode (per operator architectural decision).
// We never invoke a system-installed `opencode` binary — instead we run
// our forked opencode from source via `bun`. The fork is cloned by
// install.sh to ~/.cheapcode/opencode (or operator-defined CHEAPCODE_OPENCODE).

const OPENCODE_FORK_PATH = process.env.CHEAPCODE_OPENCODE ?? join(CHEAPCODE_HOME, "opencode")
const OPENCODE_FORK_PKG = join(OPENCODE_FORK_PATH, "packages", "opencode")
const OPENCODE_FORK_ENTRY = join(OPENCODE_FORK_PKG, "src", "index.ts")

function ensureOpencodeFork(): void {
  if (!existsSync(OPENCODE_FORK_ENTRY)) {
    console.error(C.red(`cheapcode opencode fork not found at ${OPENCODE_FORK_PATH}.`))
    console.error(C.dim("re-run install:"))
    console.error("")
    console.error(`    ${C.cyan("curl -fsSL https://raw.githubusercontent.com/MahmoodKhalil57/cheapcode/main/install.sh | sh")}`)
    console.error("")
    console.error(C.dim("OR for dev mode (existing checkout):"))
    console.error(`    ${C.cyan("CHEAPCODE_SOURCE=$(pwd) bash install.sh")}`)
    process.exit(2)
  }
}

function getOpencodeVersion(): string | null {
  // Read packages/opencode/package.json from the fork
  const pkgPath = join(OPENCODE_FORK_PKG, "package.json")
  if (!existsSync(pkgPath)) return null
  try {
    const pkg = JSON.parse(readFileSync(pkgPath, "utf-8"))
    return pkg.version ? `${pkg.version} (cheapcode fork)` : null
  } catch {
    return null
  }
}

/**
 * Spawn the forked opencode from source. Mirrors opencode's own `bun dev`
 * convention: bun --cwd <pkg> --conditions=browser src/index.ts
 */
function spawnOpencodeFork(args: string[], opts: { stdio?: "inherit" | "pipe" } = {}) {
  ensureOpencodeFork()
  return spawn(
    "bun",
    [
      "run",
      "--cwd", OPENCODE_FORK_PKG,
      "--conditions=browser",
      OPENCODE_FORK_ENTRY,
      ...args,
    ],
    { stdio: opts.stdio ?? "inherit" },
  )
}

// ============================================================
// Subcommand: version
// ============================================================

function cmdVersion(): number {
  const oc = getOpencodeVersion() ?? "(not installed)"
  console.log(`cheapcode ${CHEAPCODE_VERSION}`)
  console.log(C.dim(`  opencode: ${oc}`))
  console.log(C.dim(`  root: ${CHEAPCODE_ROOT}`))
  console.log(C.dim(`  config: ${CHEAPCODE_HOME}`))
  return 0
}

// ============================================================
// Subcommand: doctor (health check)
// ============================================================

function cmdDoctor(): number {
  console.log(C.bold("cheapcode doctor — system health check\n"))
  let issues = 0

  // 1. opencode fork
  if (existsSync(OPENCODE_FORK_ENTRY)) {
    const v = getOpencodeVersion() ?? "(version unknown)"
    console.log(`  ${C.green("[OK]")} cheapcode opencode fork at ${OPENCODE_FORK_PATH} ${C.dim(v)}`)
  } else {
    console.log(`  ${C.red("[FAIL]")} cheapcode opencode fork not found at ${OPENCODE_FORK_PATH}`)
    console.log(`    ${C.dim("re-run install.sh to clone the fork")}`)
    issues++
  }

  // 2. opencode config
  const opCfg = join(homedir(), ".config", "opencode", "opencode.json")
  if (existsSync(opCfg)) {
    try {
      JSON.parse(readFileSync(opCfg, "utf-8"))
      console.log(`  ${C.green("[OK]")} opencode config valid: ${opCfg}`)
    } catch (e) {
      console.log(`  ${C.red("[FAIL]")} opencode config malformed: ${(e as Error).message}`)
      issues++
    }
  } else {
    console.log(`  ${C.yellow("[WARN]")} no opencode config at ${opCfg}`)
  }

  // 3. cheapcode provider registered in opencode
  if (existsSync(opCfg)) {
    const cfg = JSON.parse(readFileSync(opCfg, "utf-8"))
    if (cfg.provider?.cheapcode) {
      console.log(`  ${C.green("[OK]")} cheapcode provider registered in opencode.json`)
    } else {
      console.log(`  ${C.yellow("[WARN]")} cheapcode provider NOT in opencode.json`)
      console.log(`    ${C.dim(`add "cheapcode": { "npm": "${CHEAPCODE_ROOT}", ... } to provider section`)}`)
    }
    if (cfg.mcp?.["cheapcode-accounts"]) {
      console.log(`  ${C.green("[OK]")} cheapcode-accounts MCP server registered`)
    } else {
      console.log(`  ${C.yellow("[WARN]")} cheapcode-accounts MCP server NOT in opencode.json mcp section`)
    }
  }

  // 4. accounts.json
  const acc = join(CHEAPCODE_HOME, "..", ".config", "cheapcode", "accounts.json")
  // actually use defaultRegistryPath logic
  const accPath = join(homedir(), ".config", "cheapcode", "accounts.json")
  if (existsSync(accPath)) {
    try {
      const reg = JSON.parse(readFileSync(accPath, "utf-8"))
      console.log(`  ${C.green("[OK]")} accounts.json valid: ${reg.accounts?.length ?? 0} account(s)`)
    } catch {
      console.log(`  ${C.red("[FAIL]")} accounts.json malformed`)
      issues++
    }
  } else {
    console.log(`  ${C.dim("[INFO]")} no accounts.json yet (single-account mode active)`)
  }

  // 5. opencode auth.json
  const auth = join(homedir(), ".local", "share", "opencode", "auth.json")
  if (existsSync(auth)) {
    try {
      const a = JSON.parse(readFileSync(auth, "utf-8"))
      console.log(`  ${C.green("[OK]")} opencode auth.json: ${Object.keys(a).length} provider(s)`)
    } catch {
      console.log(`  ${C.red("[FAIL]")} opencode auth.json malformed`)
      issues++
    }
  } else {
    console.log(`  ${C.yellow("[WARN]")} no opencode auth.json (run 'cheapcode providers login' first)`)
  }

  console.log()
  if (issues === 0) {
    console.log(C.green("all checks passed"))
    return 0
  }
  console.log(C.red(`${issues} issue(s) found`))
  return 1
}

// ============================================================
// Subcommand: web
// ============================================================

async function cmdWeb(extraArgs: string[]): Promise<number> {
  ensureOpencodeFork()
  const portIdx = extraArgs.indexOf("--port")
  const port = portIdx === -1 ? DEFAULT_WEB_PORT : parseInt(extraArgs[portIdx + 1] ?? `${DEFAULT_WEB_PORT}`, 10)
  if (isNaN(port)) fail(`invalid --port value`)

  console.log(C.bold("cheapcode web"))
  console.log()
  console.log(`  ${C.cyan("→")} launching cheapcode (forked opencode) from source...`)
  console.log(`  ${C.dim(`source: ${OPENCODE_FORK_PATH}`)}`)

  // Point opencode at our pre-built packages/app/dist (built once at install
  // time). Fork patch in shared/ui.ts respects OPENCODE_UI_DIST and serves
  // local files instead of proxying upstream — that's how the native
  // "+ Add another" button reaches the browser.
  const uiDist = join(OPENCODE_FORK_PATH, "packages", "app", "dist")
  if (existsSync(uiDist)) {
    console.log(`  ${C.dim(`UI dist: ${uiDist}`)}`)
  } else {
    console.log(C.yellow(`  warning: ${uiDist} not found — UI will proxy upstream (no '+ Add another' button).`))
    console.log(C.dim(`  run: bun --cwd ${OPENCODE_FORK_PATH}/packages/app build`))
  }
  console.log()

  const passthroughArgs = extraArgs.filter((_, i) => i !== portIdx && i !== portIdx + 1)
  const args = ["web", "--port", `${port}`, ...passthroughArgs]
  const child = spawn(
    "bun",
    [
      "run",
      "--cwd", OPENCODE_FORK_PKG,
      "--conditions=browser",
      OPENCODE_FORK_ENTRY,
      ...args,
    ],
    {
      stdio: "inherit",
      env: existsSync(uiDist)
        ? { ...process.env, OPENCODE_UI_DIST: uiDist }
        : process.env,
    },
  )

  setTimeout(() => {
    console.log()
    console.log(C.bold("how to use:"))
    console.log()
    console.log(`  1. open ${C.cyan(`http://127.0.0.1:${port}/`)}`)
    console.log(`  2. ${C.bold("Settings → Server → Providers")}`)
    console.log(`  3. click ${C.cyan("Connect")} for first credential per provider`)
    console.log(`  4. for ${C.bold("multiple accounts of same provider")}: click ${C.cyan("+ Add another")}`)
    console.log(`     ${C.dim("(native button — cheapcode fork patch)")}`)
    console.log(`  5. verify from a shell: ${C.cyan("cheapcode accounts list")}`)
    console.log()
    console.log(C.dim(`  ctrl-c to stop`))
    console.log()
  }, 2500)

  return await new Promise<number>((resolve) => {
    child.on("close", (code) => resolve(code ?? 0))
  })
}

// ============================================================
// Subcommand: tui
// ============================================================

function cmdTui(extraArgs: string[]): number {
  const child = spawnOpencodeFork(extraArgs)
  return new Promise<number>((resolve) => {
    child.on("close", (code) => resolve(code ?? 0))
  }) as never
}

// ============================================================
// Subcommand: run
// ============================================================

function cmdRun(extraArgs: string[]): number {
  const child = spawnOpencodeFork(["run", ...extraArgs])
  return new Promise<number>((resolve) => {
    child.on("close", (code) => resolve(code ?? 0))
  }) as never
}

// ============================================================
// Subcommand: providers (delegate to opencode providers)
// ============================================================

function cmdProviders(extraArgs: string[]): number {
  const child = spawnOpencodeFork(["providers", ...extraArgs])
  return new Promise<number>((resolve) => {
    child.on("close", (code) => resolve(code ?? 0))
  }) as never
}

// ============================================================
// Subcommand: accounts (delegate to bin/cheapcode-accounts)
// ============================================================

function cmdAccounts(extraArgs: string[]): number {
  const accBin = join(CHEAPCODE_ROOT, "bin", "cheapcode-accounts")
  if (!existsSync(accBin)) {
    fail(`cheapcode-accounts binary not found at ${accBin}`)
  }
  const child = spawn("bun", [accBin, ...extraArgs], { stdio: "inherit" })
  return new Promise<number>((resolve) => {
    child.on("close", (code) => resolve(code ?? 0))
  }) as never
}

// ============================================================
// Subcommand: status (diagnostic)
// ============================================================

function cmdStatus(extraArgs: string[]): number {
  const statusBin = join(CHEAPCODE_ROOT, "bin", "cheapcode-account-status")
  if (!existsSync(statusBin)) {
    fail(`cheapcode-account-status binary not found at ${statusBin}`)
  }
  const child = spawn("bun", [statusBin, ...extraArgs], { stdio: "inherit" })
  return new Promise<number>((resolve) => {
    child.on("close", (code) => resolve(code ?? 0))
  }) as never
}

// ============================================================
// Subcommand: update (skeleton — re-runs install script)
// ============================================================

function cmdUpdate(): number {
  console.log(C.bold("cheapcode update"))
  console.log()
  console.log(C.yellow("self-update is not yet implemented in this version."))
  console.log()
  console.log("for now, update manually:")
  console.log()
  console.log(`  ${C.cyan(`cd ${CHEAPCODE_ROOT}`)}`)
  console.log(`  ${C.cyan(`git pull`)}`)
  console.log(`  ${C.cyan(`bun install`)}`)
  console.log()
  console.log(C.dim("future: 'cheapcode update' will re-run the install script,"))
  console.log(C.dim("fetching the latest cheapcode release from the distribution channel."))
  return 0
}

// ============================================================
// Subcommand: help
// ============================================================

function printHelp(): void {
  console.log(`${C.bold("cheapcode")} ${C.dim(CHEAPCODE_VERSION)} — substrate-disciplined opencode wrapper

${C.bold("usage:")}
  ${C.cyan("cheapcode")} ${C.bold("<command>")} [options]

${C.bold("commands:")}
  ${C.cyan("web")}                start opencode web (browser UI for providers + chat)
  ${C.cyan("tui")}                start opencode TUI
  ${C.cyan("run")} ${C.dim("<message>")}      non-interactive run via opencode
  ${C.cyan("providers")} ${C.dim("<sub>")}    manage opencode-side credentials (delegate)
  ${C.cyan("accounts")} ${C.dim("<sub>")}     manage cheapcode-side multi-account metadata
                       ${C.dim("subcommands: list, show, add, remove, update, login")}
  ${C.cyan("status")}             diagnostic: account registry + auth resolution
  ${C.cyan("doctor")}             system health check (opencode + configs + MCP)
  ${C.cyan("version")}            print version
  ${C.cyan("update")}             self-update (skeleton)
  ${C.cyan("help")}               this text

${C.bold("simple flow (non-technical user):")}
  ${C.cyan("cheapcode web")}                          ${C.dim("# open browser, add providers, chat to register")}

${C.bold("technical flow (CLI):")}
  ${C.cyan("cheapcode providers login openrouter")}   ${C.dim("# opencode OAuth/api-key entry")}
  ${C.cyan("cheapcode accounts add")}                 ${C.dim("# interactive metadata registration")}
  ${C.cyan("cheapcode accounts list")}                ${C.dim("# verify")}
  ${C.cyan("cheapcode run --model=cheapcode/cheap-fast \"hi\"")}

${C.bold("docs:")} ${C.dim("https://github.com/saastemly/cheapcode (when published)")}
`)
}

// ============================================================
// Main
// ============================================================

async function main(): Promise<number> {
  const argv = process.argv.slice(2)
  const cmd = argv[0]
  const rest = argv.slice(1)

  if (!cmd || cmd === "--help" || cmd === "-h" || cmd === "help") {
    printHelp()
    return 0
  }
  if (cmd === "--version" || cmd === "-v" || cmd === "version") return cmdVersion()
  if (cmd === "doctor") return cmdDoctor()
  if (cmd === "web") return await cmdWeb(rest)
  if (cmd === "tui") return await (cmdTui(rest) as unknown as Promise<number>)
  if (cmd === "run") return await (cmdRun(rest) as unknown as Promise<number>)
  if (cmd === "providers" || cmd === "auth") return await (cmdProviders(rest) as unknown as Promise<number>)
  if (cmd === "accounts" || cmd === "acc") return await (cmdAccounts(rest) as unknown as Promise<number>)
  if (cmd === "status") return await (cmdStatus(rest) as unknown as Promise<number>)
  if (cmd === "update") return cmdUpdate()
  // Unknown — passthrough to forked opencode (so e.g. `cheapcode models` works)
  console.log(C.dim(`(unknown cheapcode command "${cmd}"; passing through to opencode fork)`))
  const child = spawnOpencodeFork(argv)
  return new Promise<number>((resolve) => {
    child.on("close", (code) => resolve(code ?? 0))
  })
}

main()
  .then((code) => process.exit(code))
  .catch((e) => {
    console.error(C.red(`fatal: ${(e as Error).message}`))
    process.exit(1)
  })
