#!/usr/bin/env bun
/**
 * cheapcode — unified CLI entry point (M6 of distribution-as-product trajectory).
 *
 * Telos per operator directive 2026-05-04: distribution-grade product modeled
 * after opencode.ai/download. Short-term curl-install for CLI; mid-term
 * desktop + VSCode extension. Updates when cheapcode updates, not when
 * opencode updates.
 *
 * Subcommands:
 *   web                    — start opencode web with cheapcode wired in (simple flow)
 *   tui                    — start opencode TUI with cheapcode loaded
 *   run <message...>       — non-interactive run via opencode
 *   providers <subcmd>     — manage opencode-side credentials (delegate)
 *   accounts <subcmd>      — manage cheapcode-side multi-account metadata
 *   status                 — diagnostic: registry + opencode auth resolution
 *   doctor                 — health-check: opencode installed, configs valid, MCP loaded
 *   version                — print cheapcode version
 *   update                 — re-run install script for self-update (skeleton)
 *   help                   — this text
 *
 * Embraces opencode spirit: opencode handles auth flows + UI shell; cheapcode
 * adds the multi-account metadata layer + tier dispatch wrapper.
 */

import { spawn, spawnSync } from "node:child_process"
import { existsSync, readFileSync, mkdirSync } from "node:fs"
import { homedir } from "node:os"
import { dirname, join } from "node:path"
import { fileURLToPath } from "node:url"
import { ensureCheapcodeDefaults } from "../src/default-config"
import { buildUpdateBanner, checkForUpdates } from "../src/version-check"

// ============================================================
// Version + paths
// ============================================================

const CHEAPCODE_VERSION = "0.1.0-pre" // bumped per release
const CHEAPCODE_HOME = process.env.CHEAPCODE_HOME ?? join(homedir(), ".cheapcode")
const DEFAULT_WEB_PORT = 4096

// cheapcode-isolated XDG paths — must match the fork's global.ts logic
// when CHEAPCODE_FORK=1 (path.join("cheapcode", "opencode")). These are the
// paths the forked runtime ACTUALLY reads/writes, so doctor + status must
// inspect these, not the vanilla opencode locations.
const XDG_DATA_HOME = process.env.XDG_DATA_HOME ?? join(homedir(), ".local", "share")
const XDG_CONFIG_HOME = process.env.XDG_CONFIG_HOME ?? join(homedir(), ".config")
const CHEAPCODE_FORK_DATA = join(XDG_DATA_HOME, "cheapcode", "opencode")
const CHEAPCODE_FORK_CONFIG = join(XDG_CONFIG_HOME, "cheapcode", "opencode")
const CHEAPCODE_FORK_OPENCODE_JSON = join(CHEAPCODE_FORK_CONFIG, "opencode.json")
const CHEAPCODE_FORK_AUTH_JSON = join(CHEAPCODE_FORK_DATA, "auth.json")
// vanilla locations (only used by migrate / doctor read-only checks)
const VANILLA_OPENCODE_JSON = join(XDG_CONFIG_HOME, "opencode", "opencode.json")
const VANILLA_AUTH_JSON = join(XDG_DATA_HOME, "opencode", "auth.json")

function getCheapcodeRoot(): string {
  // The repo this binary was built/run from. When installed via curl-install,
  // this is ~/.cheapcode/lib/cheapcode. During development it's the repo path.
  // fileURLToPath handles Windows file:///C:/... URLs correctly (without it,
  // the leading slash from the URL becomes an invalid path on Windows).
  const here = fileURLToPath(import.meta.url)
  let dir = dirname(here)
  while (dir !== dirname(dir)) {
    if (existsSync(join(dir, "package.json"))) {
      try {
        const pkg = JSON.parse(readFileSync(join(dir, "package.json"), "utf-8"))
        if (pkg.name === "@cheapcode/ai-sdk-provider" || pkg.name === "cheapcode-ai") return dir
      } catch {
        // ignore parse errors, keep walking
      }
    }
    dir = dirname(dir)
  }
  // Fallback: assume we're at <root>/bin/cheapcode
  return dirname(dirname(here))
}

const CHEAPCODE_ROOT = getCheapcodeRoot()

function ensureDefaultOpencodeConfig(): ReturnType<typeof ensureCheapcodeDefaults> {
  return ensureCheapcodeDefaults({
    opencodeConfigPath: CHEAPCODE_FORK_OPENCODE_JSON,
    cheapcodeRoot: CHEAPCODE_ROOT,
    accountsMcpCommand: join(CHEAPCODE_ROOT, "bin", "cheapcode-accounts-mcp"),
  })
}

// ============================================================
// Output (color codes; no emojis per CLAUDE.md)
// ============================================================

const C = {
  red: (s: string) => `\x1b[31m${s}\x1b[0m`,
  green: (s: string) => `\x1b[32m${s}\x1b[0m`,
  yellow: (s: string) => `\x1b[33m${s}\x1b[0m`,
  cyan: (s: string) => `\x1b[36m${s}\x1b[0m`,
  blue: (s: string) => `\x1b[34m${s}\x1b[0m`,
  magenta: (s: string) => `\x1b[35m${s}\x1b[0m`,
  dim: (s: string) => `\x1b[2m${s}\x1b[0m`,
  bold: (s: string) => `\x1b[1m${s}\x1b[0m`,
}

function fail(msg: string): never {
  console.error(C.red(`error: ${msg}`))
  process.exit(1)
}

// ============================================================
// Cheapcode-opencode fork resolution
// ============================================================
// Cheapcode IS a fork of opencode (per operator architectural decision).
// We never invoke a system-installed `opencode` binary — instead we run
// our forked opencode from source via `bun`. The fork is cloned by
// install.sh to ~/.cheapcode/opencode (or operator-defined CHEAPCODE_OPENCODE).

const OPENCODE_FORK_PATH = process.env.CHEAPCODE_OPENCODE ?? join(CHEAPCODE_HOME, "opencode")
const OPENCODE_FORK_PKG = join(OPENCODE_FORK_PATH, "packages", "opencode")
const OPENCODE_FORK_ENTRY = join(OPENCODE_FORK_PKG, "src", "index.ts")
const OPENCODE_BIN = process.env.CHEAPCODE_OPENCODE_BIN

function ensureOpencodeFork(): void {
  if (OPENCODE_BIN) {
    if (!existsSync(OPENCODE_BIN)) {
      console.error(C.red(`cheapcode opencode binary not found at ${OPENCODE_BIN}.`))
      process.exit(2)
    }
    return
  }
  if (!existsSync(OPENCODE_FORK_ENTRY)) {
    console.error(C.red(`cheapcode opencode fork not found at ${OPENCODE_FORK_PATH}.`))
    console.error(C.dim("re-run install:"))
    console.error("")
    console.error(`    ${C.cyan("curl -fsSL https://raw.githubusercontent.com/MahmoodKhalil57/cheapcode/main/install.sh | sh")}`)
    console.error("")
    console.error(C.dim("OR for dev mode (existing checkout):"))
    console.error(`    ${C.cyan("CHEAPCODE_SOURCE=$(pwd) bash install.sh")}`)
    process.exit(2)
  }
}

function getOpencodeVersion(): string | null {
  if (OPENCODE_BIN) {
    const r = spawnSync(OPENCODE_BIN, ["--version"], { encoding: "utf8" })
    const version = r.stdout.trim() || r.stderr.trim()
    return version ? `${version} (cheapcode fork binary)` : null
  }
  // Read packages/opencode/package.json from the fork
  const pkgPath = join(OPENCODE_FORK_PKG, "package.json")
  if (!existsSync(pkgPath)) return null
  try {
    const pkg = JSON.parse(readFileSync(pkgPath, "utf-8"))
    return pkg.version ? `${pkg.version} (cheapcode fork)` : null
  } catch {
    return null
  }
}

/**
 * Spawn the forked opencode from source. Mirrors opencode's own `bun dev`
 * convention: bun --cwd <pkg> --conditions=browser src/index.ts
 *
 * Always sets CHEAPCODE_FORK=1 in the child env so the forked runtime nests
 * its XDG paths under cheapcode/opencode/. Vanilla opencode (different binary,
 * default app="opencode") sees ZERO shared filesystem state.
 */
function spawnOpencodeFork(args: string[], opts: { stdio?: "inherit" | "pipe"; env?: NodeJS.ProcessEnv } = {}) {
  ensureOpencodeFork()
  if (OPENCODE_BIN) {
    return spawn(OPENCODE_BIN, args, {
      stdio: opts.stdio ?? "inherit",
      env: { ...process.env, ...(opts.env ?? {}), CHEAPCODE_FORK: "1" },
    })
  }
  return spawn(
    "bun",
    [
      "run",
      "--cwd", OPENCODE_FORK_PKG,
      "--conditions=browser",
      OPENCODE_FORK_ENTRY,
      ...args,
    ],
    {
      stdio: opts.stdio ?? "inherit",
      env: { ...process.env, ...(opts.env ?? {}), CHEAPCODE_FORK: "1" },
    },
  )
}

// ============================================================
// Subcommand: version
// ============================================================

function cmdVersion(): number {
  const oc = getOpencodeVersion() ?? "(not installed)"
  console.log(`cheapcode ${CHEAPCODE_VERSION}`)
  console.log(C.dim(`  opencode: ${oc}`))
  console.log(C.dim(`  root: ${CHEAPCODE_ROOT}`))
  console.log(C.dim(`  config: ${CHEAPCODE_HOME}`))
  return 0
}

// ============================================================
// Subcommand: doctor (health check)
// ============================================================

function cmdDoctor(): number {
  const defaults = ensureDefaultOpencodeConfig()
  console.log(C.bold("cheapcode doctor — system health check\n"))
  let issues = 0

  // 1. opencode fork
  if (existsSync(OPENCODE_FORK_ENTRY)) {
    const v = getOpencodeVersion() ?? "(version unknown)"
    console.log(`  ${C.green("[OK]")} cheapcode opencode fork at ${OPENCODE_FORK_PATH} ${C.dim(v)}`)
  } else {
    console.log(`  ${C.red("[FAIL]")} cheapcode opencode fork not found at ${OPENCODE_FORK_PATH}`)
    console.log(`    ${C.dim("re-run install.sh to clone the fork")}`)
    issues++
  }

  // 2. cheapcode-isolated opencode config
  if (existsSync(CHEAPCODE_FORK_OPENCODE_JSON)) {
    try {
      JSON.parse(readFileSync(CHEAPCODE_FORK_OPENCODE_JSON, "utf-8"))
      console.log(`  ${C.green("[OK]")} cheapcode opencode.json valid: ${CHEAPCODE_FORK_OPENCODE_JSON}`)
      if (defaults.changed) console.log(`    ${C.dim("self-healed missing cheapcode provider/MCP defaults")}`)
    } catch (e) {
      console.log(`  ${C.red("[FAIL]")} cheapcode opencode.json malformed: ${(e as Error).message}`)
      issues++
    }
  } else {
    console.log(`  ${C.yellow("[WARN]")} no cheapcode opencode.json at ${CHEAPCODE_FORK_OPENCODE_JSON}`)
    console.log(`    ${C.dim("re-run install.sh to scaffold; or run cheapcode migrate-from-vanilla if you have an existing vanilla setup.")}`)
  }

  // 3. cheapcode provider registered in cheapcode opencode.json
  if (existsSync(CHEAPCODE_FORK_OPENCODE_JSON)) {
    const cfg = JSON.parse(readFileSync(CHEAPCODE_FORK_OPENCODE_JSON, "utf-8"))
    if (cfg.provider?.cheapcode) {
      console.log(`  ${C.green("[OK]")} cheapcode provider registered`)
    } else {
      console.log(`  ${C.yellow("[WARN]")} cheapcode provider NOT registered`)
    }
    if (cfg.mcp?.["cheapcode-accounts"]) {
      console.log(`  ${C.green("[OK]")} cheapcode-accounts MCP server registered`)
    } else {
      console.log(`  ${C.yellow("[WARN]")} cheapcode-accounts MCP server NOT registered`)
    }
  }

  // 4. accounts.json
  const accPath = join(homedir(), ".config", "cheapcode", "accounts.json")
  if (existsSync(accPath)) {
    try {
      const reg = JSON.parse(readFileSync(accPath, "utf-8"))
      console.log(`  ${C.green("[OK]")} accounts.json valid: ${reg.accounts?.length ?? 0} account(s)`)
    } catch {
      console.log(`  ${C.red("[FAIL]")} accounts.json malformed`)
      issues++
    }
  } else {
    console.log(`  ${C.dim("[INFO]")} no accounts.json yet (single-account mode active)`)
  }

  // 5. cheapcode-isolated auth.json
  if (existsSync(CHEAPCODE_FORK_AUTH_JSON)) {
    try {
      const a = JSON.parse(readFileSync(CHEAPCODE_FORK_AUTH_JSON, "utf-8"))
      console.log(`  ${C.green("[OK]")} cheapcode auth.json: ${Object.keys(a).length} provider(s)`)
    } catch {
      console.log(`  ${C.red("[FAIL]")} cheapcode auth.json malformed`)
      issues++
    }
  } else {
    console.log(`  ${C.yellow("[WARN]")} no cheapcode auth.json (connect a provider via 'cheapcode web')`)
    if (existsSync(VANILLA_AUTH_JSON)) {
      console.log(
        `    ${C.dim(`note: vanilla opencode auth.json detected at ${VANILLA_AUTH_JSON}.`)}`,
      )
      console.log(
        `    ${C.dim("run 'cheapcode migrate-from-vanilla' to copy those credentials into cheapcode's isolated store.")}`,
      )
    }
  }

  console.log()
  if (issues === 0) {
    console.log(C.green("all checks passed"))
    return 0
  }
  console.log(C.red(`${issues} issue(s) found`))
  return 1
}

// ============================================================
// Subcommand: web
// ============================================================

async function cmdWeb(extraArgs: string[]): Promise<number> {
  ensureOpencodeFork()
  ensureDefaultOpencodeConfig()
  const portIdx = extraArgs.indexOf("--port")
  const port = portIdx === -1 ? DEFAULT_WEB_PORT : parseInt(extraArgs[portIdx + 1] ?? `${DEFAULT_WEB_PORT}`, 10)
  if (isNaN(port)) fail(`invalid --port value`)

  console.log(C.bold("cheapcode web"))
  console.log()
  await printUpdateBannerIfAvailable()
  console.log(`  ${C.cyan("→")} launching cheapcode (forked opencode) from source...`)
  console.log(`  ${C.dim(`source: ${OPENCODE_FORK_PATH}`)}`)

  // Point opencode at our pre-built packages/app/dist (built once at install
  // time). Fork patch in shared/ui.ts respects OPENCODE_UI_DIST and serves
  // local files instead of proxying upstream — that's how the native
  // "+ Add another" button reaches the browser.
  const uiDist = join(OPENCODE_FORK_PATH, "packages", "app", "dist")
  if (existsSync(uiDist)) {
    console.log(`  ${C.dim(`UI dist: ${uiDist}`)}`)
    // Write a small JSON the fork's settings-general tile reads to surface
    // version + update status in the browser. Non-tech users who never see
    // the terminal banner discover updates here.
    try {
      const result = checkForUpdates({
        cheapcodeRoot: CHEAPCODE_ROOT,
        forkPath: OPENCODE_FORK_PATH,
      })
      const info = {
        version: 1,
        cheapcode_version: CHEAPCODE_VERSION,
        cheapcode_repo: "https://github.com/MahmoodKhalil57/cheapcode",
        fork_repo: "https://github.com/MahmoodKhalil57/opencode",
        update_status: result,
        update_command: "cheapcode update",
        generated_at: new Date().toISOString(),
      }
      mkdirSync(uiDist, { recursive: true })
      const fs = await import("node:fs/promises")
      await fs.writeFile(join(uiDist, "cheapcode-info.json"), JSON.stringify(info, null, 2))
    } catch {
      // info file is courtesy; CLI banner is the load-bearing surface
    }
  } else {
    console.log(C.yellow(`  warning: ${uiDist} not found — UI will proxy upstream (no '+ Add another' button).`))
    console.log(C.dim(`  run: bun --cwd ${OPENCODE_FORK_PATH}/packages/app build`))
  }
  console.log()

  const passthroughArgs = extraArgs.filter((_, i) => i !== portIdx && i !== portIdx + 1)
  const args = ["web", "--port", `${port}`, ...passthroughArgs]
  const child = OPENCODE_BIN
    ? spawn(OPENCODE_BIN, args, {
        stdio: "inherit",
        env: {
          ...process.env,
          CHEAPCODE_FORK: "1",
          ...(existsSync(uiDist) ? { OPENCODE_UI_DIST: uiDist } : {}),
        },
      })
    : spawn(
        "bun",
        [
          "run",
          "--cwd", OPENCODE_FORK_PKG,
          "--conditions=browser",
          OPENCODE_FORK_ENTRY,
          ...args,
        ],
        {
          stdio: "inherit",
          env: {
            ...process.env,
            // CHEAPCODE_FORK=1 nests XDG paths under cheapcode/opencode/ so we
            // never read or write vanilla opencode's auth.json / opencode.json.
            CHEAPCODE_FORK: "1",
            ...(existsSync(uiDist) ? { OPENCODE_UI_DIST: uiDist } : {}),
          },
        },
      )

  setTimeout(() => {
    console.log()
    console.log(C.bold("how to use:"))
    console.log()
    console.log(`  1. open ${C.cyan(`http://127.0.0.1:${port}/`)}`)
    console.log(`  2. ${C.bold("Settings → Server → Providers")}`)
    console.log(`  3. click ${C.cyan("Connect")} for first credential per provider`)
    console.log(`  4. for ${C.bold("multiple accounts of same provider")}: click ${C.cyan("+ Add another")}`)
    console.log(`     ${C.dim("(native button — cheapcode fork patch)")}`)
    console.log(`  5. verify from a shell: ${C.cyan("cheapcode accounts list")}`)
    console.log()
    console.log(C.dim(`  ctrl-c to stop`))
    console.log()
  }, 2500)

  return await new Promise<number>((resolve) => {
    child.on("close", (code) => resolve(code ?? 0))
  })
}

// ============================================================
// Subcommand: tui
// ============================================================

async function cmdTui(extraArgs: string[]): Promise<number> {
  ensureDefaultOpencodeConfig()
  // Banner before launching the TUI so it appears in the operator's terminal
  // before the TUI takes over the screen.
  await printUpdateBannerIfAvailable()
  const child = spawnOpencodeFork(extraArgs)
  return await new Promise<number>((resolve) => {
    child.on("close", (code) => resolve(code ?? 0))
  })
}

// ============================================================
// Subcommand: run
// ============================================================

function cmdRun(extraArgs: string[]): number {
  ensureDefaultOpencodeConfig()
  const child = spawnOpencodeFork(["run", ...extraArgs])
  return new Promise<number>((resolve) => {
    child.on("close", (code) => resolve(code ?? 0))
  }) as never
}

// ============================================================
// Subcommand: providers (delegate to opencode providers)
// ============================================================

function cmdProviders(extraArgs: string[]): number {
  ensureDefaultOpencodeConfig()
  const child = spawnOpencodeFork(["providers", ...extraArgs])
  return new Promise<number>((resolve) => {
    child.on("close", (code) => resolve(code ?? 0))
  }) as never
}

// ============================================================
// Subcommand: accounts (delegate to bin/cheapcode-accounts)
// ============================================================

function cmdAccounts(extraArgs: string[]): number {
  const accBin = join(CHEAPCODE_ROOT, "bin", "cheapcode-accounts")
  if (!existsSync(accBin)) {
    fail(`cheapcode-accounts binary not found at ${accBin}`)
  }
  const child = spawn("bun", [accBin, ...extraArgs], { stdio: "inherit" })
  return new Promise<number>((resolve) => {
    child.on("close", (code) => resolve(code ?? 0))
  }) as never
}

// ============================================================
// Subcommand: status (diagnostic)
// ============================================================

function cmdStatus(extraArgs: string[]): number {
  const statusBin = join(CHEAPCODE_ROOT, "bin", "cheapcode-account-status")
  if (!existsSync(statusBin)) {
    fail(`cheapcode-account-status binary not found at ${statusBin}`)
  }
  const child = spawn("bun", [statusBin, ...extraArgs], { stdio: "inherit" })
  return new Promise<number>((resolve) => {
    child.on("close", (code) => resolve(code ?? 0))
  }) as never
}

// ============================================================
// Subcommand: migrate-from-vanilla
// ============================================================
//
// One-shot helper for operators who installed cheapcode AFTER having vanilla
// opencode. Copies credentials (auth.json) + MCP/provider config from
// ~/.config/opencode + ~/.local/share/opencode into cheapcode's isolated
// store at ~/.config/cheapcode/opencode + ~/.local/share/cheapcode/opencode.
// Vanilla files are left UNTOUCHED; this is a copy, not a move.
//
// --dry-run prints what would be copied without doing it.
// --force overwrites existing cheapcode files.

async function cmdMigrateFromVanilla(extraArgs: string[]): Promise<number> {
  const dryRun = extraArgs.includes("--dry-run") || extraArgs.includes("-n")
  const force = extraArgs.includes("--force") || extraArgs.includes("-f")

  console.log(C.bold("cheapcode migrate-from-vanilla"))
  console.log()
  console.log(C.dim("  copies vanilla opencode credentials + config into cheapcode's isolated store."))
  console.log(C.dim("  vanilla files are NOT modified — this is a copy, not a move."))
  console.log()

  type Mig = { from: string; to: string; label: string; transform?: (raw: string) => string }
  const migrations: Mig[] = [
    { from: VANILLA_AUTH_JSON, to: CHEAPCODE_FORK_AUTH_JSON, label: "auth.json (connected providers)" },
    { from: VANILLA_OPENCODE_JSON, to: CHEAPCODE_FORK_OPENCODE_JSON, label: "opencode.json (config)" },
  ]

  let copied = 0
  let skipped = 0
  for (const m of migrations) {
    if (!existsSync(m.from)) {
      console.log(`  ${C.dim("[skip]")} ${m.label}: source missing (${m.from})`)
      skipped++
      continue
    }
    if (existsSync(m.to) && !force) {
      console.log(`  ${C.yellow("[skip]")} ${m.label}: destination exists (pass --force to overwrite)`)
      console.log(`    ${C.dim(`from: ${m.from}`)}`)
      console.log(`    ${C.dim(`to:   ${m.to}`)}`)
      skipped++
      continue
    }
    if (dryRun) {
      console.log(`  ${C.cyan("[would-copy]")} ${m.label}`)
      console.log(`    ${C.dim(`from: ${m.from}`)}`)
      console.log(`    ${C.dim(`to:   ${m.to}`)}`)
      copied++
      continue
    }
    try {
      const raw = readFileSync(m.from, "utf-8")
      const out = m.transform ? m.transform(raw) : raw
      mkdirSync(dirname(m.to), { recursive: true })
      const fs = await import("node:fs/promises")
      await fs.writeFile(m.to, out, { mode: 0o600 })
      console.log(`  ${C.green("[copied]")} ${m.label} → ${m.to}`)
      copied++
    } catch (e) {
      console.log(`  ${C.red("[fail]")} ${m.label}: ${(e as Error).message}`)
    }
  }

  console.log()
  if (dryRun) {
    console.log(C.dim(`dry-run complete: ${copied} would be copied, ${skipped} skipped.`))
    console.log(C.dim(`re-run without --dry-run to apply.`))
  } else {
    console.log(C.green(`migration complete: ${copied} copied, ${skipped} skipped.`))
    if (copied > 0) {
      console.log(C.dim(`  next: run 'cheapcode web' — your providers should appear in Settings → Providers.`))
    }
  }
  return 0
}

// ============================================================
// Subcommand: update — pulls latest cheapcode + fork from GitHub
// ============================================================

interface RepoUpdate {
  label: string
  path: string
  branch: string
  rebuildPackagesApp?: boolean
}

function runStreaming(cmd: string, args: string[], cwd: string): { code: number; ok: boolean } {
  const r = spawnSync(cmd, args, { cwd, stdio: "inherit" })
  if (r.error) {
    console.error(C.red(`  failed to run ${cmd}: ${r.error.message}`))
    return { code: 1, ok: false }
  }
  return { code: r.status ?? 1, ok: r.status === 0 }
}

function shaShort(sha: string): string {
  return /^[0-9a-f]+$/.test(sha) ? sha.slice(0, 7) : sha
}

function updateRepo(repo: RepoUpdate, force: boolean): { ok: boolean; updated: boolean; before?: string; after?: string } {
  if (!existsSync(join(repo.path, ".git"))) {
    console.log(`  ${C.yellow("[skip]")} ${repo.label}: not a git checkout (${repo.path})`)
    return { ok: true, updated: false }
  }
  const before = spawnSync("git", ["-C", repo.path, "rev-parse", "HEAD"], { encoding: "utf8" }).stdout.trim()

  // Fetch + check for working-tree changes
  const fetch = runStreaming("git", ["-C", repo.path, "fetch", "--quiet", "origin", repo.branch], repo.path)
  if (!fetch.ok) {
    console.log(`  ${C.red("[fail]")} ${repo.label}: git fetch failed`)
    return { ok: false, updated: false, before }
  }
  const dirty = spawnSync("git", ["-C", repo.path, "status", "--porcelain"], { encoding: "utf8" }).stdout.trim()
  if (dirty.length > 0 && !force) {
    console.log(`  ${C.yellow("[skip]")} ${repo.label}: working tree has local changes — pass --force to discard`)
    return { ok: true, updated: false, before }
  }

  const target = `origin/${repo.branch}`
  const remoteSha = spawnSync("git", ["-C", repo.path, "rev-parse", target], { encoding: "utf8" }).stdout.trim()
  if (before === remoteSha) {
    console.log(`  ${C.green("[ok]")} ${repo.label}: already at ${shaShort(before)} (${repo.branch})`)
    return { ok: true, updated: false, before, after: before }
  }

  const reset = force
    ? runStreaming("git", ["-C", repo.path, "reset", "--hard", target], repo.path)
    : runStreaming("git", ["-C", repo.path, "merge", "--ff-only", target], repo.path)
  if (!reset.ok) {
    console.log(`  ${C.red("[fail]")} ${repo.label}: ${force ? "reset" : "ff-only merge"} failed`)
    return { ok: false, updated: false, before, after: before }
  }
  const after = spawnSync("git", ["-C", repo.path, "rev-parse", "HEAD"], { encoding: "utf8" }).stdout.trim()
  console.log(`  ${C.green("[updated]")} ${repo.label}: ${shaShort(before)} → ${shaShort(after)}`)
  return { ok: true, updated: true, before, after }
}

async function cmdUpdate(extraArgs: string[]): Promise<number> {
  if (process.env.CHEAPCODE_HOMEBREW === "1") {
    console.log(C.bold("cheapcode update"))
    console.log()
    console.log("  this cheapcode install is managed by Homebrew.")
    console.log("  use Homebrew to upgrade the Cellar package and relink wrappers:")
    console.log()
    console.log(`    ${C.cyan("brew update && brew upgrade cheapcode")}`)
    console.log()
    console.log("  if you installed the HEAD formula:")
    console.log()
    console.log(`    ${C.cyan("brew update && brew reinstall --HEAD cheapcode")}`)
    console.log()
    console.log(C.dim("  user config/auth remains in ~/.config/cheapcode and ~/.local/share/cheapcode."))
    return 0
  }

  const force = extraArgs.includes("--force") || extraArgs.includes("-f")
  const skipBuild = extraArgs.includes("--no-build")
  const skipDeps = extraArgs.includes("--no-install")

  console.log(C.bold("cheapcode update"))
  console.log()
  console.log(`  fetching latest from GitHub...`)
  console.log()

  // Warn if cheapcode web is running on the default port
  const probe = spawnSync("bash", ["-lc", "ss -ltn 2>/dev/null | grep -E ':4096\\s' | head -1"], { encoding: "utf8" })
  if (probe.stdout.trim().length > 0) {
    console.log(C.yellow(`  note: cheapcode web appears to be running on :4096; restart it after the update completes.`))
    console.log()
  }

  const repos: RepoUpdate[] = [
    { label: "cheapcode (lib)", path: CHEAPCODE_ROOT, branch: "main" },
    { label: "cheapcode-opencode (fork)", path: OPENCODE_FORK_PATH, branch: "dev", rebuildPackagesApp: true },
  ]

  let allOk = true
  let anyUpdated = false
  let appNeedsRebuild = false
  for (const repo of repos) {
    const r = updateRepo(repo, force)
    allOk = allOk && r.ok
    if (r.updated) {
      anyUpdated = true
      if (repo.rebuildPackagesApp) appNeedsRebuild = true
    }
  }

  if (!allOk) {
    console.log()
    console.log(C.red(`update encountered failures; see output above.`))
    return 1
  }

  if (!anyUpdated) {
    console.log()
    console.log(C.green(`already up to date.`))
    // best-effort cache invalidation so the banner stops showing
    try {
      const cache = join(homedir(), ".cache", "cheapcode", "version-check.json")
      if (existsSync(cache)) {
        spawnSync("rm", ["-f", cache])
      }
    } catch {}
    return 0
  }

  // bun install per repo (only when something updated, both repos benefit)
  if (!skipDeps) {
    console.log()
    console.log(`  installing dependencies...`)
    for (const repo of repos) {
      if (!existsSync(join(repo.path, "package.json"))) continue
      const r = runStreaming("bun", ["install", "--silent"], repo.path)
      if (!r.ok) {
        console.log(C.yellow(`  warning: bun install failed in ${repo.label}; manual run may be needed.`))
      }
    }
  }

  // rebuild packages/app if the fork updated
  if (appNeedsRebuild && !skipBuild) {
    console.log()
    console.log(`  rebuilding packages/app SPA...`)
    const appDir = join(OPENCODE_FORK_PATH, "packages", "app")
    if (existsSync(appDir)) {
      const r = runStreaming("bun", ["run", "build"], appDir)
      if (!r.ok) {
        console.log(C.yellow(`  warning: packages/app build failed; UI may fall back to upstream proxy.`))
      }
    }
  }

  // invalidate the version-check cache so the banner reflects the update
  try {
    const cache = join(homedir(), ".cache", "cheapcode", "version-check.json")
    if (existsSync(cache)) spawnSync("rm", ["-f", cache])
  } catch {}

  console.log()
  console.log(C.green(`update complete.`))
  console.log(C.dim(`  if cheapcode web/tui is running, restart it to load the new version.`))
  return 0
}

/**
 * Print a one-line banner if updates are available. Called at the start of
 * `cheapcode web` and `cheapcode tui`. Fail-soft: any error → silent.
 * Cached 24h via ~/.cache/cheapcode/version-check.json so we don't hit the
 * network on every CLI invocation.
 */
async function printUpdateBannerIfAvailable(): Promise<void> {
  try {
    if (process.env.CHEAPCODE_NO_UPDATE_CHECK === "1") return
    const result = checkForUpdates({
      cheapcodeRoot: CHEAPCODE_ROOT,
      forkPath: OPENCODE_FORK_PATH,
    })
    const banner = buildUpdateBanner(result)
    if (banner) {
      console.log()
      console.log(C.yellow(banner))
      console.log()
    }
  } catch {
    // silent fail-soft
  }
}

// ============================================================
// Subcommand: help
// ============================================================

function printHelp(): void {
  console.log(`${C.bold("cheapcode")} ${C.dim(CHEAPCODE_VERSION)} — substrate-disciplined opencode wrapper

${C.bold("usage:")}
  ${C.cyan("cheapcode")} ${C.bold("<command>")} [options]

${C.bold("commands:")}
  ${C.cyan("web")}                start opencode web (browser UI for providers + chat)
  ${C.cyan("tui")}                start opencode TUI
  ${C.cyan("run")} ${C.dim("<message>")}      non-interactive run via opencode
  ${C.cyan("providers")} ${C.dim("<sub>")}    manage opencode-side credentials (delegate)
  ${C.cyan("accounts")} ${C.dim("<sub>")}     manage cheapcode-side multi-account metadata
                       ${C.dim("subcommands: list, show, add, remove, update, login")}
  ${C.cyan("status")}             diagnostic: account registry + auth resolution
  ${C.cyan("doctor")}             system health check (opencode + configs + MCP)
  ${C.cyan("version")}            print version
  ${C.cyan("update")}             pull latest cheapcode + fork from GitHub (--force, --no-build, --no-install)
  ${C.cyan("migrate-from-vanilla")} copy vanilla opencode auth.json + opencode.json into cheapcode's isolated store
  ${C.cyan("help")}               this text

${C.bold("simple flow (non-technical user):")}
  ${C.cyan("cheapcode web")}                          ${C.dim("# open browser, add providers, chat to register")}

${C.bold("technical flow (CLI):")}
  ${C.cyan("cheapcode providers login openrouter")}   ${C.dim("# opencode OAuth/api-key entry")}
  ${C.cyan("cheapcode accounts add")}                 ${C.dim("# interactive metadata registration")}
  ${C.cyan("cheapcode accounts list")}                ${C.dim("# verify")}
  ${C.cyan("cheapcode run --model=cheapcode/cheap-fast \"hi\"")}

${C.bold("docs:")} ${C.dim("https://github.com/saastemly/cheapcode (when published)")}
`)
}

// ============================================================
// Main
// ============================================================

async function main(): Promise<number> {
  const argv = process.argv.slice(2)
  const cmd = argv[0]
  const rest = argv.slice(1)

  if (!cmd || cmd === "--help" || cmd === "-h" || cmd === "help") {
    printHelp()
    return 0
  }
  if (cmd === "--version" || cmd === "-v" || cmd === "version") return cmdVersion()
  if (cmd === "doctor") return cmdDoctor()
  if (cmd === "web") return await cmdWeb(rest)
  if (cmd === "tui") return await cmdTui(rest)
  if (cmd === "run") return await (cmdRun(rest) as unknown as Promise<number>)
  if (cmd === "providers" || cmd === "auth") return await (cmdProviders(rest) as unknown as Promise<number>)
  if (cmd === "accounts" || cmd === "acc") return await (cmdAccounts(rest) as unknown as Promise<number>)
  if (cmd === "status") return await (cmdStatus(rest) as unknown as Promise<number>)
  if (cmd === "update") return await cmdUpdate(rest)
  if (cmd === "migrate-from-vanilla" || cmd === "migrate") return await cmdMigrateFromVanilla(rest)
  // Unknown — passthrough to forked opencode (so e.g. `cheapcode models` works)
  console.log(C.dim(`(unknown cheapcode command "${cmd}"; passing through to opencode fork)`))
  const child = spawnOpencodeFork(argv)
  return new Promise<number>((resolve) => {
    child.on("close", (code) => resolve(code ?? 0))
  })
}

main()
  .then((code) => process.exit(code))
  .catch((e) => {
    console.error(C.red(`fatal: ${(e as Error).message}`))
    process.exit(1)
  })
